# ──────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────
APP_NAME=nimbus-starter
APP_ENV=development
APP_KEY=
HOST=0.0.0.0
PORT=3333

# ──────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ──────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────
DB_DRIVER=sqlite
DB_DSN=database.sqlite
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_DATABASE=nimbus

# ──────────────────────────────────────────────────────────
# Session
# ──────────────────────────────────────────────────────────
SESSION_DRIVER=cookie
SESSION_COOKIE=nimbus_session
SESSION_MAX_AGE=604800

# ──────────────────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────────────────
AUTH_GUARD=session
TOKEN_EXPIRES_IN=86400

# ──────────────────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────────────────
CORS_ENABLED=true
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# ──────────────────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ──────────────────────────────────────────────────────────
# Mail (SMTP)
# ──────────────────────────────────────────────────────────
MAIL_DRIVER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Nimbus App

# ──────────────────────────────────────────────────────────
# Cache
# ──────────────────────────────────────────────────────────
CACHE_DRIVER=memory
CACHE_TTL_MINUTES=60

# ──────────────────────────────────────────────────────────
# Hashing
# ──────────────────────────────────────────────────────────
HASH_DRIVER=bcrypt
HASH_BCRYPT_COST=10

# ──────────────────────────────────────────────────────────
# AI SDK
# ──────────────────────────────────────────────────────────
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini-2024-07-18
OPENAI_API_KEY=
# For local dev without API key: AI_PROVIDER=ollama, AI_MODEL=llama3.2
# OLLAMA_HOST=http://localhost:11434

# ──────────────────────────────────────────────────────────
# Static Files
# ──────────────────────────────────────────────────────────
STATIC_ENABLED=true
STATIC_ROOT=public
STATIC_PREFIX=/public

# ──────────────────────────────────────────────────────────
# Storage
# ──────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_ROOT=storage

# ──────────────────────────────────────────────────────────
# Queue
# ──────────────────────────────────────────────────────────
QUEUE_DRIVER=redis
REDIS_URL=redis://localhost:6379
SQS_QUEUE_URL=
KAFKA_BROKERS=
KAFKA_TOPIC=
KAFKA_GROUP_ID=
