@layout('layout-demos')
<!-- HERO -->
<div class="hero ruled fi">
  <div class="corners" aria-hidden="true"><b class="tl"></b><b class="tr"></b><b class="bl"></b><b class="br"></b></div>
  <div class="wrap">
    <a href="/demos" class="back-link fi d1">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 19l-7-7 7-7"/></svg>
      All demos
    </a>
    <div class="eyebrow fi d2"><hr>Demo &middot; AI SDK<hr></div>
    <div class="hero-row">
      <div>
        <h1 class="hero-h1 fi d3"><span class="grad">AI SDK</span> Demo</h1>
        <p class="hero-sub fi d4">Enter a prompt and get an AI-generated response. Works with OpenAI, Ollama, Anthropic, and any compatible provider.</p>
      </div>
      <div class="hero-badge fi d5">
        <span class="badge-dot"></span>
        Provider active
      </div>
    </div>
  </div>
</div>

<!-- MAIN -->
<section class="main-section ruled">
  <div class="corners" aria-hidden="true"><b class="bl"></b><b class="br"></b></div>
  <div class="wrap">
    <div class="content-grid">

      <!-- LEFT: Form + result -->
      <div class="fi d1">
        <div class="card">
          <div class="card-header">
            <div class="card-title-row">
              <div class="card-icon-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              </div>
              <span class="card-label">Generate a response</span>
            </div>
            <span class="card-hint">POST /demos/ai/generate</span>
          </div>
          <div class="card-body">
            <form method="POST" action="/demos/ai/generate" id="ai-form" up-submit up-target="#ai-result" up-keep-url>
              {{ .csrfField }}
              <div>
                <label for="prompt" class="field-label">Prompt</label>
                <textarea
                  id="prompt"
                  name="prompt"
                  rows="5"
                  placeholder="e.g. Explain quantum computing in one sentence"
                  oninput="updateCount(this)"
                ></textarea>
                <p class="field-hint">Be specific for better results. Supports any natural language prompt.</p>
              </div>
              <div class="form-footer">
                <span class="char-count" id="char-count">0 characters</span>
                <button type="submit" class="submit-btn" id="submit-btn">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                  Generate
                </button>
              </div>
            </form>

            <div class="result-wrap">
              <div class="result-label-row">
                <span class="result-label">Response</span>
                <span class="result-status" id="result-status">Waiting for input</span>
              </div>
              @include('apps/ai/result')
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Sidebar -->
      <div class="sidebar fi d2">

        <!-- How it works -->
        <div class="info-card">
          <h3>How it works</h3>
          <div class="info-row"><span class="info-dot"></span><span class="info-text"><strong>ai.Generate()</strong> — single blocking call that returns the full text response</span></div>
          <div class="info-row"><span class="info-dot"></span><span class="info-text"><strong>ai.Stream()</strong> — returns a channel you pipe into ctx.SSE() for token streaming</span></div>
          <div class="info-row"><span class="info-dot"></span><span class="info-text"><strong>Provider config</strong> — set in config/ai.go, switch providers with one line</span></div>
          <div class="info-row"><span class="info-dot"></span><span class="info-text"><strong>Zero JS required</strong> — streaming handled natively by Nimbus SSE helpers</span></div>
        </div>

        <!-- Providers -->
        <div class="info-card">
          <h3>Supported providers</h3>
          <div class="provider-row">
            <span class="ptag">openai</span>
            <span class="ptag">ollama</span>
            <span class="ptag">anthropic</span>
            <span class="ptag">groq</span>
            <span class="ptag">mistral</span>
            <span class="ptag">gemini</span>
          </div>
        </div>

        <!-- Code card -->
        <div class="code-card">
          <div class="code-card-bar">
            <div class="cd cdr"></div><div class="cd cdy"></div><div class="cd cdg"></div>
            <span>handlers/ai.go</span>
          </div>
          <pre><span class="kw">func</span> (<span class="type">H</span>) <span class="fn">Generate</span>(
  ctx <span class="op">*</span><span class="type">http.Context</span>,
  req <span class="op">*</span><span class="type">AIRequest</span>,
) <span class="type">error</span> {

  text, err <span class="op">:=</span> ai.<span class="fn">Generate</span>(
    ctx, req.Prompt,
  )
  <span class="kw">if</span> err <span class="op">!=</span> <span class="num">nil</span> {
    <span class="kw">return</span> ctx.<span class="fn">InternalError</span>(err)
  }

  <span class="kw">return</span> ctx.<span class="fn">View</span>(
    <span class="str">"apps/ai/result"</span>,
    nimbus.<span class="type">Map</span>{
      <span class="str">"text"</span>: text,
    },
  )
}</pre>
        </div>

      </div><!-- /sidebar -->
    </div><!-- /content-grid -->
  </div>
</section>
