<div id="ai-result" class="p-4 min-h-[120px]">
  @if(.error)
  <p class="text-red-500 text-sm">{{ .error }}</p>
  @else if(.text)
  <p class="text-sm whitespace-pre-wrap leading-relaxed">{{ .text }}</p>
  @else
  <p class="text-slate-500 text-sm">Submit a prompt above to see the AI response.</p>
  @endif
</div>
