<h2 class="text-xl font-semibold text-slate-900 dark:text-white mt-8 mb-2">HTTP Middleware</h2>
<pre data-file="start/routes.go"><code>// Rate-limit AI endpoints (10 requests per second per IP)
aiGroup := app.Router.Group("/api/ai")
aiGroup.Use(ai.RateLimit(10, time.Second))
aiGroup.Use(ai.CostGuard(1.00)) // max $1 per request
aiGroup.Use(ai.Logger())
aiGroup.Post("/chat", chatHandler)
aiGroup.Post("/generate", generateHandler)</code></pre>

