<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ .title }} — Nimbus</title>

  {{/* Fonts */}}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wdth,wght@0,75..125,200..900;1,75..125,200..900&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">

  {{/* Design system — all shared CSS lives here */}}
  <link rel="stylesheet" href="/public/css/app.css">

  {{/* Unpoly — progressive enhancement, partial page updates */}}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/unpoly@3.12.0/unpoly.min.css">
  <script src="https://cdn.jsdelivr.net/npm/unpoly@3.12.0/unpoly.min.js"></script>
  <script>
    // Client-side prototype extensions (loaded once via layout)
    if (!Array.prototype.forEachPromise) {
      Array.prototype.forEachPromise = async function(callback) {
        var that = this;
        for (var index = 0; index < that.length; index++) {
          await callback(that[index], index, that);
        }
      };
    }

    if (!Array.prototype.mapPromise) {
      Array.prototype.mapPromise = async function(callback) {
        var that = this;
        for (var index = 0; index < that.length; index++) {
          that[index] = await callback(that[index], index, that);
        }
        return that;
      };
    }

    // Theme-specific confirmation override
    // We set it after Unpoly loads
    up.layer.confirm = function(options) {
      alert('Override running for: ' + options.confirm);
      console.log('Unpoly confirmation triggered:', options.confirm);
      if (!options.confirm) return Promise.resolve();
      
      return up.layer.ask('/demos/todo/confirm', {
        data: { 
          title: 'Confirm Action', 
          message: options.confirm 
        },
        target: '.m-confirm',
        size: 'small',
        dismissable: 'button key'
      });
    };
  </script>
</head>
<body>

  <!-- ── NAV ── -->
  <header>
    <nav>
      <a href="/" class="logo">
        <div class="logo-icon">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>
          </svg>
        </div>
        Nimbus
      </a>

      <div class="nav-mid">
        <a href="/"       class="nav-link">Framework</a>
        <a href="#"       class="nav-link">Packages</a>
        <a href="#"       class="nav-link">Resources</a>
        <a href="/demos"  class="nav-link {{ if .activeDemos }}active{{ end }}">Demos</a>
        <a href="#"       class="nav-link">Docs</a>
      </div>

      <div class="nav-end">
        <a href="https://github.com/CodeSyncr/nimbus" target="_blank" rel="noopener" class="btn-gh">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/>
          </svg>
          GitHub
        </a>
        <a href="https://github.com/CodeSyncr/nimbus" target="_blank" rel="noopener" class="btn-start">
          Get started
        </a>
      </div>
    </nav>
  </header>

  <!-- ── PAGE CONTENT ── -->
  <main up-main>
    {{ .embed }}
  </main>

  <!-- ── FOOTER ── -->
  <footer>
    <div class="footer-in">
      <p>&#169; 2025 <a href="/">Nimbus</a> &middot; AdonisJS-style framework for Go</p>
      <div class="flinks">
        <a href="/">Home</a>
        <a href="/demos">Demos</a>
        <a href="/health">Health</a>
        <a href="https://github.com/CodeSyncr/nimbus" target="_blank" rel="noopener">GitHub</a>
        <a href="#">Docs</a>
      </div>
    </div>
  </footer>

</body>
</html>
