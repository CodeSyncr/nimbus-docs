    <!-- Main content -->
    <main class="flex-1 min-w-0 overflow-y-auto bg-white dark:bg-slate-950 transition-colors" up-main>
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 docs-content">
        {{ .embed }}
        @if(or .prevSlug .nextSlug)
        <nav class="flex flex-col sm:flex-row gap-4 justify-between mt-16 pt-8 border-t border-slate-200 dark:border-slate-800">
          @if(.prevSlug)
          <a href="/docs/{{ .prevSlug }}" class="group flex-1 flex items-center gap-2 p-4 rounded-xl border border-slate-200 dark:border-slate-700 hover:border-amber-500/50 dark:hover:border-amber-500/50 hover:bg-amber-50/50 dark:hover:bg-amber-500/5 transition-all">
            <svg class="w-5 h-5 text-slate-400 group-hover:text-amber-600 dark:group-hover:text-amber-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            <div class="min-w-0">
              <span class="text-xs font-medium uppercase tracking-wider text-slate-400 block">Previous</span>
              <span class="font-medium text-slate-800 dark:text-white truncate block">{{ .prevTitle }}</span>
            </div>
          </a>
          @else
          <div class="flex-1"></div>
          @endif
          @if(.nextSlug)
          <a href="/docs/{{ .nextSlug }}" class="group flex-1 flex items-center gap-2 p-4 rounded-xl border border-slate-200 dark:border-slate-700 hover:border-amber-500/50 dark:hover:border-amber-500/50 hover:bg-amber-50/50 dark:hover:bg-amber-500/5 transition-all sm:flex-row-reverse text-right sm:text-left">
            <svg class="w-5 h-5 text-slate-400 group-hover:text-amber-600 dark:group-hover:text-amber-400 shrink-0 sm:order-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <div class="min-w-0 flex-1">
              <span class="text-xs font-medium uppercase tracking-wider text-slate-400 block">Next</span>
              <span class="font-medium text-slate-800 dark:text-white truncate block">{{ .nextTitle }}</span>
            </div>
          </a>
          @else
          <div class="flex-1"></div>
          @endif
        </nav>
        @endif
        <footer class="border-t border-slate-200 dark:border-slate-800 mt-16 py-6 transition-colors">
          <div class="text-center text-slate-500 dark:text-slate-400 text-sm">
            <a href="/docs" class="text-amber-600 dark:text-amber-400 hover:text-amber-700 dark:hover:text-amber-300">Documentation</a> · Built with <a href="https://github.com/CodeSyncr/nimbus" class="text-amber-600 dark:text-amber-400 hover:text-amber-700 dark:hover:text-amber-300">Nimbus</a> · AdonisJS-style framework for Go
          </div>
        </footer>
      </div>
    </main>

    <!-- Right sidebar: On This Page -->
    <aside class="hidden xl:block w-56 shrink-0 border-l border-slate-200 dark:border-slate-800 overflow-y-auto transition-colors" up-hungry up-transition="cross-fade">
      <div class="p-4">
        <div class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-3">On this page</div>
        <nav id="on-this-page" class="space-y-1.5 text-sm text-slate-600 dark:text-slate-400">
          <a href="#" class="block py-1 hover:text-amber-600 dark:hover:text-amber-400 transition">Overview</a>
        </nav>
      </div>
    </aside>
  </div>

  <!-- Search modal -->
  <div id="docs-search-modal" class="fixed inset-0 z-50 hidden" aria-hidden="true">
    <div class="fixed inset-0 bg-black/50" id="docs-search-backdrop"></div>
    <div class="fixed inset-x-4 top-20 sm:inset-x-1/4 sm:top-1/4 max-h-[70vh] overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 shadow-2xl">
      <div class="p-2 border-b border-slate-200 dark:border-slate-700">
        <input id="docs-search-input" type="search" placeholder="Search documentation..." autocomplete="off" class="w-full px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 border-0 text-slate-900 dark:text-white placeholder-slate-500 focus:ring-2 focus:ring-amber-500/50 transition" />
      </div>
      <div id="docs-search-results" class="overflow-y-auto max-h-[60vh] p-2 text-sm"></div>
    </div>
  </div>

  <!-- AI chat button & centered modal -->
  <button id="docs-ai-toggle" type="button" aria-label="Ask AI" class="fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full bg-gradient-to-br from-amber-500 to-orange-600 text-white shadow-lg hover:shadow-xl hover:scale-105 transition-all flex items-center justify-center">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
  </button>
  <div id="docs-ai-modal" class="fixed inset-0 z-50 hidden" aria-hidden="true">
    <div class="fixed inset-0 bg-black/50" id="docs-ai-backdrop"></div>
    <div class="fixed inset-x-4 top-[10%] bottom-[10%] sm:inset-x-[15%] sm:top-[8%] sm:bottom-[8%] flex flex-col rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 shadow-2xl overflow-hidden">
      <div class="p-4 border-b border-slate-200 dark:border-slate-700 bg-amber-50/50 dark:bg-amber-900/10 shrink-0">
        <h3 class="font-semibold text-slate-900 dark:text-white">Ask about Nimbus docs</h3>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">Ask anything related to the documentation.</p>
        <div id="docs-ai-suggestions" class="flex flex-wrap gap-2 mt-3">
          <button type="button" class="docs-ai-suggestion px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-400 text-xs hover:border-amber-500/50 hover:text-amber-600 dark:hover:text-amber-400 transition">How do I set up routing?</button>
          <button type="button" class="docs-ai-suggestion px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-400 text-xs hover:border-amber-500/50 hover:text-amber-600 dark:hover:text-amber-400 transition">How do I use middleware?</button>
          <button type="button" class="docs-ai-suggestion px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-400 text-xs hover:border-amber-500/50 hover:text-amber-600 dark:hover:text-amber-400 transition">How do I use the cache?</button>
          <button type="button" class="docs-ai-suggestion px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-400 text-xs hover:border-amber-500/50 hover:text-amber-600 dark:hover:text-amber-400 transition">How do I add authentication?</button>
          <button type="button" class="docs-ai-suggestion px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-400 text-xs hover:border-amber-500/50 hover:text-amber-600 dark:hover:text-amber-400 transition">How do I run database migrations?</button>
          <button type="button" class="docs-ai-suggestion px-3 py-1.5 rounded-lg bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-600 text-slate-600 dark:text-slate-400 text-xs hover:border-amber-500/50 hover:text-amber-600 dark:hover:text-amber-400 transition">How do I validate request data?</button>
        </div>
      </div>
      <div id="docs-ai-messages" class="flex-1 overflow-y-auto p-4 space-y-3 min-h-0"></div>
      <form id="docs-ai-form" class="p-4 border-t border-slate-200 dark:border-slate-700 shrink-0">
        <div class="flex gap-2">
          <input id="docs-ai-input" type="text" placeholder="Ask a question..." class="flex-1 px-3 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white placeholder-slate-500 focus:ring-2 focus:ring-amber-500/50 text-sm" />
          <button type="submit" class="px-4 py-2 rounded-lg bg-amber-500 hover:bg-amber-600 text-white font-medium text-sm transition">Send</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    (function() {
      const storageKey = 'theme';
      const getTheme = () => localStorage.getItem(storageKey) || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      const applyTheme = (theme) => {
        document.documentElement.classList.toggle('dark', theme === 'dark');
        localStorage.setItem(storageKey, theme);
      };
      applyTheme(getTheme());
      document.addEventListener('click', (e) => {
        if (e.target.closest('#theme-toggle')) {
          const next = getTheme() === 'dark' ? 'light' : 'dark';
          applyTheme(next);
        }
      });
    })();
    function processAiCodeBlocks(container) {
      if (!container) return;
      container.querySelectorAll('pre code').forEach(function(codeEl) {
        var pre = codeEl.parentElement;
        var text = codeEl.textContent || '';
        var lines = text.split('\n');
        var firstLine = lines[0] || '';
        var match = firstLine.match(/^(\/\/|#)\s*File:\s*(.+)$/);
        if (match) {
          pre.setAttribute('data-file', match[2].trim());
          codeEl.textContent = lines.slice(1).join('\n').replace(/^\n+/, '');
        }
      });
      initCodeBlocks(container);
      container.querySelectorAll('pre code').forEach(function(el) {
        if (!el.className || (!el.className.includes('language-') && !el.className.includes('hljs'))) {
          var t = el.textContent.trim();
          if (t.match(/^(package |import |func |type |var |const |\/\/)/m)) el.classList.add('language-go');
          else if (t.match(/^(\$|#|go |nimbus |npm |cd |export |curl )/m)) el.classList.add('language-bash');
        }
        if (typeof hljs !== 'undefined') hljs.highlightElement(el);
      });
    }
    function initCodeBlocks(container) {
      if (!container) return;
      var pres = container.querySelectorAll('pre:not(.code-block-init)');
      pres.forEach(function(pre) {
        pre.classList.add('code-block-init');
        var wrapper = document.createElement('div');
        wrapper.className = 'code-block';
        var file = pre.getAttribute('data-file') || '';
        var header = document.createElement('div');
        header.className = 'code-block-header';
        header.innerHTML = '<span class="code-block-file">' + (file || 'Code') + '</span>' +
          '<button type="button" class="code-block-copy" aria-label="Copy to clipboard">' +
          '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>' +
          '</button>';
        var btn = header.querySelector('.code-block-copy');
        btn.addEventListener('click', function() {
          var code = pre.querySelector('code');
          var text = code ? code.textContent : pre.textContent;
          navigator.clipboard.writeText(text).then(function() {
            btn.classList.add('copied');
            btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>';
            setTimeout(function() {
              btn.classList.remove('copied');
              btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>';
            }, 1500);
          });
        });
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(header);
        wrapper.appendChild(pre);
      });
    }
    up.compiler('.docs-content', function(el) {
      initCodeBlocks(el);
    });
    up.compiler('.docs-content pre code', function(el) {
      if (!el.className || (!el.className.includes('language-') && !el.className.includes('hljs'))) {
        var text = el.textContent.trim();
        if (text.match(/^(package |import |func |type |var |const |\/\/)/m)) {
          el.classList.add('language-go');
        } else if (text.match(/^(\$|#|go |nimbus |npm |cd |export |curl )/m)) {
          el.classList.add('language-bash');
        }
      }
      if (typeof hljs !== 'undefined') hljs.highlightElement(el);
    });
    up.link.config.followSelectors.push('[up-nav] a[href^="/docs/"]');
    up.link.config.preloadSelectors.push('[up-nav] a[href^="/docs/"]');
    up.fragment.config.navigateOptions.transition = 'cross-fade';
    // Ensure only main content is replaced so sidebar scroll position is preserved
    document.querySelectorAll('[up-nav] a[href^="/docs/"]').forEach(function(a) {
      a.setAttribute('up-target', '[up-main]');
    });
    up.compiler('.docs-content', function(main) {
      var toc = document.getElementById('on-this-page');
      if (!toc) return;
      var headings = main.querySelectorAll('h2, h3');
      if (headings.length === 0) return;
      toc.innerHTML = '';
      headings.forEach(function(h) {
        var id = h.id || (h.textContent.replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase().replace(/^-|-$/g, ''));
        if (!h.id) h.id = id;
        var a = document.createElement('a');
        a.href = '#' + id;
        a.className = 'block py-1 hover:text-amber-600 dark:hover:text-amber-400 transition' + (h.tagName === 'H3' ? ' pl-3 text-slate-500 dark:text-slate-400' : '');
        a.textContent = h.textContent;
        toc.appendChild(a);
      });
    });
    up.on('up:fragment:inserted', function(event) {
      var main = document.querySelector('[up-main]');
      if (main && event.target.closest('[up-main]')) {
        main.scrollTop = 0;
        initCodeBlocks(main.querySelector('.docs-content'));
      }
    });

    // Docs search (Cmd+K)
    var docsSearchModal = document.getElementById('docs-search-modal');
    var docsSearchInput = document.getElementById('docs-search-input');
    var docsSearchResults = document.getElementById('docs-search-results');
    var docsSearchBackdrop = document.getElementById('docs-search-backdrop');
    var docsIndex = [];
    var docsFuse = null;

    function openDocsSearch() {
      if (docsSearchModal) {
        docsSearchModal.classList.remove('hidden');
        docsSearchModal.setAttribute('aria-hidden', 'false');
        docsSearchInput.value = '';
        docsSearchInput.focus();
        docsSearchResults.innerHTML = '<p class="p-4 text-slate-500 dark:text-slate-400 text-sm">Type to search...</p>';
      }
    }
    function closeDocsSearch() {
      if (docsSearchModal) {
        docsSearchModal.classList.add('hidden');
        docsSearchModal.setAttribute('aria-hidden', 'true');
      }
    }

    document.getElementById('docs-search-trigger')?.addEventListener('click', openDocsSearch);
    docsSearchBackdrop?.addEventListener('click', closeDocsSearch);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        if (docsSearchModal?.classList.contains('hidden')) openDocsSearch();
        else closeDocsSearch();
      }
      if (e.key === 'Escape') closeDocsSearch();
    });

    fetch('/api/docs/index').then(function(r) { return r.json(); }).then(function(data) {
      docsIndex = data;
      docsFuse = typeof Fuse !== 'undefined' ? new Fuse(data, { keys: ['title', 'slug'], threshold: 0.3 }) : null;
    });

    docsSearchInput?.addEventListener('input', function() {
      var q = this.value.trim();
      if (!docsFuse || !q) {
        docsSearchResults.innerHTML = q ? '<p class="p-4 text-slate-500 dark:text-slate-400 text-sm">No results.</p>' : '<p class="p-4 text-slate-500 dark:text-slate-400 text-sm">Type to search...</p>';
        return;
      }
      var hits = docsFuse.search(q).slice(0, 12);
      docsSearchResults.innerHTML = hits.length ? hits.map(function(h) {
        return '<a href="/docs/' + h.item.slug + '" class="block px-4 py-2 rounded-lg hover:bg-amber-50 dark:hover:bg-amber-500/10 text-slate-700 dark:text-slate-300">' + h.item.title + '</a>';
      }).join('') : '<p class="p-4 text-slate-500 dark:text-slate-400 text-sm">No results.</p>';
    });

    docsSearchInput?.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeDocsSearch();
    });

    // AI chat (centered modal like search)
    var docsAiToggle = document.getElementById('docs-ai-toggle');
    var docsAiModal = document.getElementById('docs-ai-modal');
    var docsAiBackdrop = document.getElementById('docs-ai-backdrop');
    var docsAiForm = document.getElementById('docs-ai-form');
    var docsAiInput = document.getElementById('docs-ai-input');
    var docsAiMessages = document.getElementById('docs-ai-messages');
    var docsCurrentSlug = {{ if .currentSlug }}"{{ .currentSlug }}"{{ else }}""{{ end }};

    function openDocsAi() {
      if (docsAiModal) {
        docsAiModal.classList.remove('hidden');
        docsAiModal.setAttribute('aria-hidden', 'false');
        docsAiInput.focus();
      }
    }
    function closeDocsAi() {
      if (docsAiModal) {
        docsAiModal.classList.add('hidden');
        docsAiModal.setAttribute('aria-hidden', 'true');
      }
    }

    docsAiToggle?.addEventListener('click', openDocsAi);
    docsAiBackdrop?.addEventListener('click', closeDocsAi);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && docsAiModal && !docsAiModal.classList.contains('hidden')) closeDocsAi();
    });

    document.querySelectorAll('.docs-ai-suggestion').forEach(function(btn) {
      btn.addEventListener('click', function() {
        docsAiInput.value = this.textContent;
        docsAiInput.focus();
      });
    });

    docsAiForm?.addEventListener('submit', function(e) {
      e.preventDefault();
      var msg = docsAiInput.value.trim();
      if (!msg) return;
      docsAiInput.value = '';
      docsAiMessages.innerHTML += '<div class="text-right"><span class="inline-block px-3 py-2 rounded-lg bg-amber-500/20 text-slate-800 dark:text-slate-200 text-sm">' + msg.replace(/</g, '&lt;') + '</span></div>';
      docsAiMessages.innerHTML += '<div class="text-left"><span class="inline-block px-3 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm">Thinking...</span></div>';
      docsAiMessages.scrollTop = docsAiMessages.scrollHeight;

      fetch('/api/docs/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, currentPage: docsCurrentSlug })
      }).then(function(r) { return r.json(); }).then(function(data) {
        var last = docsAiMessages.querySelector('.text-left:last-child');
        if (last) {
          var raw = data.text || data.error || 'Error';
          var html = (typeof marked !== 'undefined' && marked.parse) ? marked.parse(raw) : raw.replace(/</g, '&lt;').replace(/\n/g, '<br>');
          last.innerHTML = '<div class="inline-block px-3 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-sm docs-ai-response max-w-full overflow-hidden">' + html + '</div>';
          var resp = last.querySelector('.docs-ai-response');
          if (resp) processAiCodeBlocks(resp);
        }
        docsAiMessages.scrollTop = docsAiMessages.scrollHeight;
      }).catch(function(err) {
        var last = docsAiMessages.querySelector('.text-left:last-child');
        if (last) last.innerHTML = '<span class="inline-block px-3 py-2 rounded-lg bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 text-sm">Failed to get response.</span>';
      });
    });
  </script>
</body>
</html>
