<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ .title }} · Nimbus</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['DM Sans', 'system-ui', 'sans-serif'],
            mono: ['JetBrains Mono', 'ui-monospace', 'monospace']
          },
          colors: { accent: { DEFAULT: '#f59e0b', hover: '#d97706' } }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/go.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/bash.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/marked@11.1.1/marked.min.js"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/unpoly@3.12.0/unpoly.min.css">
  <script src="https://cdn.jsdelivr.net/npm/unpoly@3.12.0/unpoly.min.js"></script>
  <style>
    .code-block {
      border-radius: 0.5rem;
      overflow: hidden;
      margin-bottom: 1rem;
      border: 1px solid #334155;
      background: #0f172a;
    }
    .dark .code-block { border-color: #334155; }
    .code-block-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem 1rem;
      background: #1e293b;
      border-bottom: 1px solid #334155;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.75rem;
      color: #94a3b8;
    }
    .code-block-copy {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.25rem 0.5rem;
      border-radius: 0.25rem;
      background: transparent;
      border: 1px solid #334155;
      color: #94a3b8;
      cursor: pointer;
      transition: all 0.15s;
    }
    .code-block-copy:hover {
      background: #334155;
      color: #e2e8f0;
      border-color: #475569;
    }
    .code-block-copy.copied {
      color: #86efac;
      border-color: #86efac;
    }
    .dark .code-block-header { background: #1e293b; border-color: #334155; color: #94a3b8; }
    .dark .code-block-copy { border-color: #334155; color: #94a3b8; }
    .dark .code-block-copy:hover { background: #334155; color: #e2e8f0; }
    .docs-content pre {
      font-size: 0.8125rem;
      background: #0f172a !important;
      border: none !important;
      border-radius: 0;
      padding: 1rem 1.25rem;
      margin: 0 !important;
      overflow-x: auto;
    }
    .dark .docs-content pre {
      background: #0f172a !important;
      border: none !important;
    }
    .docs-content pre code {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.8125rem;
      line-height: 1.6;
      background: transparent !important;
      padding: 0 !important;
      color: #e2e8f0 !important;
    }
    .docs-content pre code .hljs-keyword { color: #fbbf24; }
    .docs-content pre code .hljs-type { color: #7dd3fc; }
    .docs-content pre code .hljs-built_in { color: #7dd3fc; }
    .docs-content pre code .hljs-string { color: #86efac; }
    .docs-content pre code .hljs-number { color: #7dd3fc; }
    .docs-content pre code .hljs-function .hljs-title,
    .docs-content pre code .hljs-title.function_ { color: #c4b5fd; }
    .docs-content pre code .hljs-comment { color: #64748b; font-style: italic; }
    .docs-content pre code .hljs-params { color: #e2e8f0; }
    .docs-content pre code .hljs-literal { color: #7dd3fc; }
    .docs-content pre code .hljs-attr { color: #7dd3fc; }
    .docs-content pre code .hljs-property { color: #7dd3fc; }
    .docs-content pre code .hljs-variable { color: #fdba74; }
    .docs-content pre code .hljs-punctuation { color: #e2e8f0; }
    .docs-content pre code .hljs-selector-class { color: #86efac; }
    .docs-content pre code .hljs-selector-tag { color: #86efac; }
    .docs-content pre code .hljs-tag { color: #86efac; }

    .docs-content code:not(pre code) {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.8em;
      background: #f1f5f9;
      padding: 0.15em 0.4em;
      border-radius: 0.25rem;
      color: #0f172a;
    }
    .dark .docs-content code:not(pre code) {
      background: #334155;
      color: #e2e8f0;
    }

    .docs-content :target { scroll-margin-top: 5rem; }
    .docs-content h2 { scroll-margin-top: 5rem; }
    .docs-content h3 { scroll-margin-top: 5rem; }
    .nav-section summary { list-style: none; cursor: pointer; }
    .nav-section summary::-webkit-details-marker { display: none; }
    .nav-section[open] .nav-chevron { transform: rotate(0deg); }
    .nav-section:not([open]) .nav-chevron { transform: rotate(-90deg); display: inline-block; }

    up-progress-bar { background-color: #f59e0b; }
    .dark up-progress-bar { background-color: #fbbf24; }

    [up-nav] a.up-current {
      background: #fef3c7;
      color: #b45309;
      font-weight: 500;
      border-left: 2px solid #f59e0b;
      margin-left: -1px;
    }
    .dark [up-nav] a.up-current {
      background: rgba(251, 191, 36, 0.15);
      color: #fbbf24;
      border-left-color: #fbbf24;
    }

    /* Nav section category labels */
    .nav-category {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #94a3b8;
      padding: 0.75rem 0.75rem 0.25rem;
      margin-top: 0.5rem;
    }
    .dark .nav-category { color: #64748b; }

    /* Section icon badge */
    .nav-icon {
      width: 1.25rem;
      height: 1.25rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 0.25rem;
      font-size: 0.7rem;
      flex-shrink: 0;
    }

    /* Nav link item count badge */
    .nav-count {
      font-size: 0.625rem;
      padding: 0.1rem 0.4rem;
      border-radius: 9999px;
      background: #f1f5f9;
      color: #64748b;
      margin-left: auto;
      font-weight: 500;
    }
    .dark .nav-count { background: #1e293b; color: #475569; }

    /* Mobile sidebar overlay */
    #mobile-sidebar-overlay {
      position: fixed;
      inset: 0;
      z-index: 40;
      background: rgba(0, 0, 0, 0.5);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }
    #mobile-sidebar-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }
    #mobile-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      z-index: 50;
      width: 18rem;
      transform: translateX(-100%);
      transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
      overflow-y: auto;
      background: white;
      border-right: 1px solid #e2e8f0;
    }
    .dark #mobile-sidebar {
      background: #0f172a;
      border-color: #1e293b;
    }
    #mobile-sidebar.active {
      transform: translateX(0);
    }

    /* Smooth details animation */
    .nav-section .nav-links {
      overflow: hidden;
      transition: max-height 0.2s ease;
    }

    /* Doc content dark mode overrides */
    .dark .docs-content h1, .dark .docs-content h2, .dark .docs-content h3 { color: #f8fafc !important; }
    .dark .docs-content p, .dark .docs-content li { color: #94a3b8 !important; }
    .dark .docs-content a:not(.up-current) { color: #fbbf24 !important; }
    .dark .docs-content a:not(.up-current):hover { color: #fcd34d !important; }
    .dark .docs-content table { border-color: #334155 !important; }
    .dark .docs-content th { background: #1e293b !important; color: #e2e8f0 !important; border-color: #334155 !important; }
    .dark .docs-content td { border-color: #334155 !important; color: #94a3b8 !important; }
    .dark .docs-content thead tr { background: #1e293b !important; }
    .dark .docs-content tbody tr { border-color: #334155 !important; }

    /* AI chat markdown formatting */
    .docs-ai-response p { margin: 0.5em 0; }
    .docs-ai-response p:first-child { margin-top: 0; }
    .docs-ai-response p:last-child { margin-bottom: 0; }
    .docs-ai-response code { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.875em; background: #f1f5f9; color: #0f172a; padding: 0.15em 0.4em; border-radius: 0.25rem; }
    .dark .docs-ai-response code { background: #334155; color: #e2e8f0; }
    .docs-ai-response pre { margin: 0.75em 0; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; background: #0f172a; border: 1px solid #334155; }
    .docs-ai-response pre code { background: transparent; padding: 0; color: #e2e8f0; }
    .docs-ai-response .code-block { margin: 0.75em 0; }
    .docs-ai-response .code-block pre { margin: 0; border-radius: 0; border: none; }
    .docs-ai-response ul, .docs-ai-response ol { margin: 0.5em 0; padding-left: 1.5em; }
    .docs-ai-response li { margin: 0.25em 0; }
    .docs-ai-response strong { font-weight: 600; }
  </style>
</head>
<body class="h-screen overflow-hidden bg-white text-slate-800 font-sans antialiased dark:bg-slate-950 dark:text-slate-200 flex flex-col transition-colors duration-300">
  <!-- Header -->
  <header class="shrink-0 z-20 border-b border-slate-200 dark:border-slate-800 bg-white/95 dark:bg-slate-950/95 backdrop-blur transition-colors">
    <div class="flex items-center justify-between h-14 px-4 gap-4">
      <div class="flex items-center gap-2">
        <button id="mobile-menu-btn" type="button" aria-label="Open navigation" class="lg:hidden p-2 -ml-2 rounded-lg text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <a href="/" class="flex items-center gap-2 shrink-0">
          <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-amber-500/30">N</span>
          <span class="font-semibold text-slate-800 dark:text-white">Nimbus</span>
        </a>
      </div>
      <div class="flex-1 max-w-xl mx-4 hidden sm:block">
        <button id="docs-search-trigger" type="button" class="w-full flex items-center gap-2 h-9 px-3 rounded-lg bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400 text-sm text-left hover:border-slate-300 dark:hover:border-slate-600 transition">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <span>Search docs</span>
          <kbd class="ml-auto text-xs px-1.5 py-0.5 rounded bg-slate-200 dark:bg-slate-700">⌘K</kbd>
        </button>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <a href="/" class="text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition">Home</a>
        <a href="/demos" class="text-sm text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition">Demos</a>
        <button id="theme-toggle" type="button" aria-label="Toggle theme" class="p-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 hover:border-amber-500/50 transition">
          <svg id="sun-icon" class="w-5 h-5 text-amber-500 hidden dark:block" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/></svg>
          <svg id="moon-icon" class="w-5 h-5 text-slate-600 dark:text-slate-400 block dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/></svg>
        </button>
        <a href="https://github.com/CodeSyncr/nimbus" target="_blank" rel="noopener" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-900 dark:bg-slate-800 text-white text-sm font-medium hover:bg-slate-800 dark:hover:bg-slate-700 transition border border-slate-700">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
          GitHub
        </a>
      </div>
    </div>
  </header>

  <div class="flex flex-1 overflow-hidden">
    <!-- Mobile sidebar overlay -->
    <div id="mobile-sidebar-overlay"></div>

    <!-- Mobile sidebar (clone of desktop, visible on small screens) -->
    <div id="mobile-sidebar">
      <div class="flex items-center justify-between p-4 border-b border-slate-200 dark:border-slate-800">
        <a href="/" class="flex items-center gap-2">
          <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center text-white font-bold text-xs">N</span>
          <span class="font-semibold text-sm text-slate-800 dark:text-white">Nimbus Docs</span>
        </a>
        <button id="mobile-menu-close" type="button" aria-label="Close navigation" class="p-1.5 rounded-lg text-slate-400 hover:text-slate-600 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <nav class="sidebar-nav p-3 space-y-0.5 text-sm" up-nav></nav>
    </div>

    <!-- Left sidebar (desktop) -->
    <aside class="hidden lg:block w-64 shrink-0 border-r border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-900/30 overflow-y-auto transition-colors" id="desktop-sidebar" up-nav>
      <nav class="sidebar-nav p-3 space-y-0.5 text-sm">

        <!-- ── Getting Started ── -->
        <div class="nav-category">Getting Started</div>

        <details class="nav-section" open data-section="start">
          <summary class="flex items-center gap-2 py-2 px-3 rounded-lg text-slate-700 dark:text-slate-300 font-medium cursor-pointer hover:bg-slate-200/60 dark:hover:bg-slate-800/60 transition-colors">
            <span class="nav-icon bg-emerald-100 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400">🚀</span>
            <span class="flex-1">Start</span>
            <span class="nav-chevron text-slate-400 text-[0.6rem] shrink-0 transition-transform">▼</span>
          </summary>
          <div class="nav-links ml-4 mt-0.5 space-y-0.5 border-l-2 border-slate-200 dark:border-slate-700/50 pl-3">
            <a href="/docs/introduction" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Introduction</a>
            <a href="/docs/installation" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Installation</a>
            <a href="/docs/folder-structure" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Folder Structure</a>
            <a href="/docs/configuration" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Configuration</a>
            <a href="/docs/deployment" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Deployment</a>
            <a href="/docs/faqs" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">FAQs</a>
          </div>
        </details>

        <details class="nav-section" data-section="resources">
          <summary class="flex items-center gap-2 py-2 px-3 rounded-lg text-slate-700 dark:text-slate-300 font-medium cursor-pointer hover:bg-slate-200/60 dark:hover:bg-slate-800/60 transition-colors">
            <span class="nav-icon bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400">📦</span>
            <span class="flex-1">Resources</span>
            <span class="nav-chevron text-slate-400 text-[0.6rem] shrink-0 transition-transform">▼</span>
          </summary>
          <div class="nav-links ml-4 mt-0.5 space-y-0.5 border-l-2 border-slate-200 dark:border-slate-700/50 pl-3">
            <a href="https://github.com/CodeSyncr/nimbus/blob/main/CONTRIBUTING.md" target="_blank" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Contributing ↗</a>
            <a href="https://github.com/CodeSyncr/nimbus/releases" target="_blank" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Releases ↗</a>
          </div>
        </details>

        <!-- ── Guides ── -->
        <div class="nav-category">Guides</div>

        <details class="nav-section" data-section="basics">
          <summary class="flex items-center gap-2 py-2 px-3 rounded-lg text-slate-700 dark:text-slate-300 font-medium cursor-pointer hover:bg-slate-200/60 dark:hover:bg-slate-800/60 transition-colors">
            <span class="nav-icon bg-sky-100 dark:bg-sky-500/20 text-sky-600 dark:text-sky-400">📖</span>
            <span class="flex-1">Basics</span>
            <span class="nav-count">14</span>
            <span class="nav-chevron text-slate-400 text-[0.6rem] shrink-0 transition-transform">▼</span>
          </summary>
          <div class="nav-links ml-4 mt-0.5 space-y-0.5 border-l-2 border-slate-200 dark:border-slate-700/50 pl-3">
            <a href="/docs/routing" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Routing</a>
            <a href="/docs/controllers" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">Controllers</a>
            <a href="/docs/http-context" class="block py-1.5 px-2 rounded text-slate-600 dark:text-slate-400 hover:bg-amber-50 dark:hover:bg-amber-500/10 hover:text-amber-700 dark:hover:text-amber-400 transition-colors text-[0.8125rem]">HTTP Context</a>
