<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ .title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wdth,wght@0,75..125,200..900;1,75..125,200..900&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --red:        #e74c3c;
      --red-dark:   #c0392b;
      --red-light:  #fef2f2;
      --orange:     #f97316;
      --border:     #e5e7eb;
      --bg:         #ffffff;
      --bg-soft:    #fafafa;
      --bg-warm:    #fffbf8;
      --text:       #111827;
      --text-mid:   #374151;
      --text-soft:  #6b7280;
      --text-dim:   #9ca3af;
      --code-bg:    #18181f;

      /*
       * GRID LINE SYSTEM
       * ─────────────────
       * The two vertical lines define a "page frame" 1280px wide.
       * They sit at the edges of this frame (or 24px from viewport edge on
       * narrow screens).
       *
       * Content lives inside a 1120px container which has an additional
       * 48px of horizontal padding → gives a consistent ~80px gap between
       * line and text at all viewport sizes that show the lines.
       *
       * Frame:   max-width 1280px  →  lines at calc(50% - 640px)
       * Content: max-width 1120px  →  inner edge at calc(50% - 560px)
       * Gap = 640 - 560 = 80px on wide screens ✓
       */
      --line-offset: max(24px, calc(50% - 640px));
      --dot-offset:  calc(var(--line-offset) - 2.5px);
    }

    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Mona Sans', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }

    /* ══════════════════════════════════════════════
       VERTICAL GRID LINE SYSTEM
       ══════════════════════════════════════════════
       .ruled   — adds the two vertical border lines
       .corners — red ■ corner marks at boundaries
    ═══════════════════════════════════════════════*/
    .ruled { position: relative; overflow: visible; }

    .ruled::before,
    .ruled::after {
      content: '';
      position: absolute;
      top: 0; bottom: 0;
      width: 1px;
      background: var(--border);
      pointer-events: none;
      z-index: 0;
    }
    .ruled::before { left:  var(--line-offset); }
    .ruled::after  { right: var(--line-offset); }

    /* Red 5×5 corner squares */
    .corners {
      position: absolute; inset: 0;
      pointer-events: none; z-index: 3;
    }
    .corners b {
      position: absolute;
      width: 5px; height: 5px;
      background: var(--red);
    }
    .corners .tl { top:    -2.5px; left:  var(--dot-offset); }
    .corners .tr { top:    -2.5px; right: var(--dot-offset); }
    .corners .bl { bottom: -2.5px; left:  var(--dot-offset); }
    .corners .br { bottom: -2.5px; right: var(--dot-offset); }

    /* ══════════════════════════════════════════════
       CONTENT WRAPPER
       Content is narrower than the line frame so
       there is always a visible gap on each side.
    ═══════════════════════════════════════════════*/
    .wrap {
      max-width: 1120px;
      margin: 0 auto;
      padding: 0 48px;      /* inner padding — always inside the lines */
      position: relative;
      z-index: 1;
    }

    /* ─── NAV ─── */
    header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255,255,255,0.94);
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
    }
    nav {
      max-width: 1120px; margin: 0 auto;
      padding: 0 48px; height: 60px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo { display: flex; align-items: center; gap: 9px; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.04em; color: var(--text); }
    .logo-icon { width: 28px; height: 28px; background: linear-gradient(135deg, var(--red) 0%, var(--orange) 100%); border-radius: 7px; display: flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
    .nav-mid { display: flex; gap: 2px; }
    .nav-link { padding: 6px 12px; border-radius: 7px; font-size: 0.85rem; font-weight: 500; color: var(--text-soft); transition: all .15s; }
    .nav-link:hover { color: var(--text); background: var(--bg-soft); }
    .nav-end { display: flex; align-items: center; gap: 8px; }
    .btn-gh { display: flex; align-items: center; gap: 6px; padding: 5px 12px; border-radius: 7px; font-size: 0.82rem; font-weight: 500; color: var(--text-soft); border: 1px solid var(--border); transition: all .15s; }
    .btn-gh:hover { color: var(--text); border-color: #d1d5db; }
    .btn-start { padding: 7px 18px; border-radius: 7px; font-size: 0.86rem; font-weight: 600; background: var(--red); color: #fff; transition: background .15s; white-space: nowrap; }
    .btn-start:hover { background: var(--red-dark); }

    /* ─── HERO ─── */
    .hero {
      background: var(--bg-warm);
      border-bottom: 1px solid var(--border);
      padding: 100px 48px 90px;
      text-align: center;
    }
    .orb { position: absolute; border-radius: 50%; pointer-events: none; filter: blur(90px); }
    .orb1 { width: 700px; height: 420px; top: -180px; left: 50%; transform: translateX(-50%); background: radial-gradient(ellipse, rgba(231,76,60,0.1) 0%, transparent 70%); }
    .orb2 { width: 360px; height: 280px; bottom: -80px; right: 8%; background: radial-gradient(ellipse, rgba(249,115,22,0.08) 0%, transparent 70%); }
    .hero-in { position: relative; max-width: 680px; margin: 0 auto; z-index: 1; }

    .eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--red); margin-bottom: 24px; }
    .eyebrow hr { width: 26px; border: none; border-top: 1.5px solid currentColor; opacity: .4; }

    .hero-h1 { font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 900; line-height: 1.06; letter-spacing: -0.045em; color: var(--text); margin-bottom: 20px; }
    .hero-h1 .grad { background: linear-gradient(120deg, var(--red) 0%, var(--orange) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }

    .hero-sub { font-size: 1.05rem; color: var(--text-soft); line-height: 1.72; max-width: 480px; margin: 0 auto 36px; }

    .ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 36px; }
    .btn { display: inline-flex; align-items: center; gap: 8px; padding: 11px 22px; border-radius: 9px; font-size: 0.88rem; font-weight: 600; transition: all .18s; border: 1px solid transparent; font-family: inherit; cursor: pointer; }
    .btn-red { background: var(--red); color: #fff; box-shadow: 0 1px 4px rgba(231,76,60,.2), 0 4px 14px rgba(231,76,60,.14); }
    .btn-red:hover { background: var(--red-dark); transform: translateY(-1px); }
    .btn-outline { background: #fff; color: var(--text-mid); border-color: var(--border); box-shadow: 0 1px 2px rgba(0,0,0,.05); }
    .btn-outline:hover { border-color: #d1d5db; box-shadow: 0 2px 10px rgba(0,0,0,.08); transform: translateY(-1px); }

    .hero-meta { font-size: 0.77rem; color: var(--text-dim); font-family: 'DM Mono', monospace; }
    .hero-meta strong { color: var(--text-soft); }

    /* ─── TRUST BAR ─── */
    .trust {
      border-bottom: 1px solid var(--border);
      padding: 16px 48px;
      background: #fff;
    }
    .trust-in { max-width: 1120px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 7px; flex-wrap: wrap; position: relative; z-index: 1; }
    .trust-label { font-size: 0.71rem; color: var(--text-dim); font-weight: 600; text-transform: uppercase; letter-spacing: .09em; margin-right: 4px; white-space: nowrap; }
    .chip { display: inline-flex; align-items: center; gap: 5px; padding: 3px 11px; border-radius: 100px; font-size: 0.74rem; font-weight: 600; background: var(--bg-soft); border: 1px solid var(--border); color: var(--text-soft); white-space: nowrap; }
    .chip-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    /* ─── SECTIONS ─── */
    section { padding: 88px 0; }
    .bg-soft { background: var(--bg-soft); }

    .sec-kicker { font-size: 0.72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
    .sec-title { font-size: clamp(1.8rem, 3vw, 2.6rem); font-weight: 800; letter-spacing: -.04em; line-height: 1.1; color: var(--text); margin-bottom: 14px; }
    .sec-sub { font-size: .96rem; color: var(--text-soft); line-height: 1.72; max-width: 480px; }
    .sec-center { text-align: center; }
    .sec-center .sec-sub { margin: 0 auto; }

    /* ─── SPLIT LAYOUT ─── */
    .split { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
    .split.rev { direction: rtl; }
    .split.rev > * { direction: ltr; }

    .bullets { list-style: none; margin-top: 24px; display: flex; flex-direction: column; gap: 10px; }
    .bullets li { display: flex; align-items: flex-start; gap: 10px; font-size: .87rem; color: var(--text-mid); line-height: 1.55; }
    .bul-ic { flex-shrink: 0; margin-top: 2px; width: 17px; height: 17px; background: var(--red-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--red); }

    .learn-more { display: inline-flex; align-items: center; gap: 6px; margin-top: 26px; font-size: .87rem; font-weight: 600; color: var(--red); transition: gap .15s; }
    .learn-more:hover { gap: 10px; }

    /* ─── CODE WINDOW ─── */
    .code-win { background: var(--code-bg); border-radius: 13px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,.14), 0 4px 16px rgba(0,0,0,.1); }
    .code-topbar { display: flex; align-items: center; justify-content: space-between; padding: 11px 15px; background: rgba(255,255,255,.03); border-bottom: 1px solid rgba(255,255,255,.06); }
    .dots { display: flex; gap: 6px; }
    .dot-w { width: 11px; height: 11px; border-radius: 50%; }
    .dr { background: #ff5f57; } .dy { background: #ffbd2e; } .dg { background: #28c840; }
    .ctabs { display: flex; gap: 2px; }
    .ctab { padding: 4px 11px; border-radius: 5px; font-size: .73rem; font-family: 'DM Mono', monospace; color: rgba(255,255,255,.3); cursor: pointer; transition: all .15s; }
    .ctab.on { color: rgba(255,255,255,.82); background: rgba(255,255,255,.08); }
    pre { padding: 22px 22px; font-family: 'DM Mono', monospace; font-size: .79rem; line-height: 1.82; overflow-x: auto; tab-size: 2; color: #dde1ed; }
    .kw { color: #c084fc; } .fn { color: #60a5fa; } .str { color: #86efac; }
    .cmt { color: #3d4f63; font-style: italic; } .num { color: #fbbf24; }
    .type { color: #67e8f9; } .op { color: #64748b; } .at { color: #fb923c; }

    /* ─── FEATURE GRID ─── */
    .fg { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-top: 52px; }
    .fc { background: #fff; padding: 28px 24px; transition: background .18s; }
    .fc:hover { background: var(--bg-soft); }
    .fi { width: 38px; height: 38px; border-radius: 9px; background: var(--red-light); display: flex; align-items: center; justify-content: center; color: var(--red); margin-bottom: 14px; }
    .fc h3 { font-size: .93rem; font-weight: 700; letter-spacing: -.02em; color: var(--text); margin-bottom: 6px; }
    .fc p  { font-size: .81rem; color: var(--text-soft); line-height: 1.65; }

    /* ─── STATS ─── */
    .stats-band { background: #111827; }
    .stats-in { max-width: 1120px; margin: 0 auto; padding: 0 48px; display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: rgba(255,255,255,.07); }
    .stat-card { background: #111827; padding: 52px 24px; text-align: center; }
    .stat-n { font-size: 2.8rem; font-weight: 900; letter-spacing: -.05em; background: linear-gradient(135deg,#fff 30%,rgba(255,255,255,.5) 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 6px; }
    .stat-t { font-size: .8rem; color: rgba(255,255,255,.38); }

    /* ─── TESTIMONIALS ─── */
    .tg { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-top: 48px; }
    .tc { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 24px; transition: box-shadow .2s, transform .2s; }
    .tc:hover { box-shadow: 0 8px 32px rgba(0,0,0,.08); transform: translateY(-2px); }
    .stars { color: #fbbf24; font-size: .74rem; margin-bottom: 13px; letter-spacing: 1px; }
    .tq { font-size: .87rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 20px; }
    .ta { display: flex; align-items: center; gap: 10px; }
    .av { width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, var(--red) 0%, var(--orange) 100%); display: flex; align-items: center; justify-content: center; font-size: .78rem; font-weight: 700; color: #fff; flex-shrink: 0; }
    .an { font-size: .83rem; font-weight: 700; color: var(--text); }
    .ar { font-size: .75rem; color: var(--text-dim); }

    /* ─── DEPLOY CTA ─── */
    .deploy { background: linear-gradient(135deg, #180808 0%, #2b0d0d 45%, #1c0e04 100%); color: #fff; text-align: center; padding: 100px 48px; }
    .deploy-h { font-size: clamp(2rem,4vw,3.2rem); font-weight: 900; letter-spacing: -.04em; line-height: 1.1; margin-bottom: 16px; }
    .deploy-h .a { background: linear-gradient(120deg,#fca5a5 0%,#fb923c 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
    .deploy-sub { font-size: .98rem; color: rgba(255,255,255,.45); max-width: 420px; margin: 0 auto 36px; line-height: 1.65; }
    .btn-wh { background: #fff; color: var(--text); box-shadow: 0 4px 20px rgba(0,0,0,.3); }
    .btn-wh:hover { background: #f8fafc; transform: translateY(-1px); }
    .btn-ghost-w { background: rgba(255,255,255,.08); color: rgba(255,255,255,.78); border: 1px solid rgba(255,255,255,.15); }
    .btn-ghost-w:hover { background: rgba(255,255,255,.13); }

    /* ─── FOOTER ─── */
    footer { background: var(--bg-soft); border-top: 1px solid var(--border); padding: 56px 0 36px; }
    .ft { max-width: 1120px; margin: 0 auto; padding: 0 48px; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 48px; }
    .fb .logo { margin-bottom: 12px; display: inline-flex; }
    .ftag { font-size: .82rem; color: var(--text-soft); line-height: 1.65; max-width: 210px; margin-top: 8px; }
    .fcol h4 { font-size: .74rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--text-mid); margin-bottom: 14px; }
    .fcol ul { list-style: none; display: flex; flex-direction: column; gap: 9px; }
    .fcol ul li a { font-size: .82rem; color: var(--text-soft); transition: color .15s; }
    .fcol ul li a:hover { color: var(--text); }
    .fb2 { max-width: 1120px; margin: 0 auto; padding: 0 48px; }
    .fb2-in { padding-top: 26px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .fb2 p { font-size: .77rem; color: var(--text-dim); }
    .fb2 a { color: var(--text-soft); transition: color .15s; }
    .fb2 a:hover { color: var(--text); }
    code.snippet { font-family: 'DM Mono', monospace; font-size: .73rem; background: #f3f4f6; padding: 2px 7px; border-radius: 4px; border: 1px solid #e5e7eb; color: var(--text-mid); }

    /* ─── ANIMATIONS ─── */
    .fi-anim { opacity: 0; transform: translateY(16px); animation: fiu .5s cubic-bezier(.22,1,.36,1) forwards; }
    @keyframes fiu { to { opacity:1; transform: translateY(0); } }
    .d1{animation-delay:.08s} .d2{animation-delay:.18s} .d3{animation-delay:.28s} .d4{animation-delay:.38s} .d5{animation-delay:.48s}

    /* ═══════════════════════════════════════════
       RESPONSIVE
    ════════════════════════════════════════════*/

    /* Large: grid lines show naturally via CSS vars */

    /* Medium (tablet) */
    @media (max-width: 1024px) {
      .wrap    { padding: 0 36px; }
      nav      { padding: 0 36px; }
      .trust   { padding: 16px 36px; }
      .hero    { padding: 80px 36px 72px; }
      .stats-in{ padding: 0; }
      .ft      { padding: 0 36px; }
      .fb2     { padding: 0 36px; }
      .deploy  { padding: 80px 36px; }
    }

    /* Tablet — hide nav centre links */
    @media (max-width: 900px) {
      .nav-mid { display: none; }

      /* Hide grid lines on tablet — viewport too narrow for them to look intentional */
      .ruled::before,
      .ruled::after,
      .corners { display: none; }

      .split, .split.rev { grid-template-columns: 1fr; direction: ltr; gap: 40px; }
      .fg     { grid-template-columns: repeat(2,1fr); }
      .stats-in { grid-template-columns: repeat(2,1fr); padding: 0; }
      .tg     { grid-template-columns: 1fr 1fr; }
      .ft     { grid-template-columns: 1fr 1fr; gap: 32px; }
      .fb     { grid-column: 1 / -1; }
    }

    /* Mobile */
    @media (max-width: 640px) {
      .wrap    { padding: 0 20px; }
      nav      { padding: 0 20px; height: 56px; }
      .btn-gh  { display: none; }
      .trust   { padding: 14px 20px; }
      .hero    { padding: 64px 20px 60px; }
      section  { padding: 64px 0; }
      .deploy  { padding: 72px 20px; }
      .ft      { padding: 0 20px; grid-template-columns: 1fr 1fr; gap: 28px; }
      .fb2     { padding: 0 20px; }

      .fg      { grid-template-columns: 1fr; }
      .stats-in{ grid-template-columns: 1fr 1fr; padding: 0; }
      .tg      { grid-template-columns: 1fr; }

      .hero-h1 { font-size: 2.2rem; }
      .ctas    { flex-direction: column; align-items: center; }
      .ctas .btn { width: 100%; max-width: 300px; justify-content: center; }

      /* Wrap chip overflow */
      .trust-in { justify-content: flex-start; overflow-x: auto; flex-wrap: nowrap; padding-bottom: 4px; }
      .trust-in::-webkit-scrollbar { display: none; }
    }

    /* Very small */
    @media (max-width: 400px) {
      .ft { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ── NAV ── -->
<header>
  <nav>
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
      </div>
      {{ .appName }}
    </a>
    <div class="nav-mid">
      <a href="#" class="nav-link">Framework</a>
      <a href="#" class="nav-link">Packages</a>
      <a href="#" class="nav-link">Resources</a>
      <a href="/demos" class="nav-link">Demos</a>
      <a href="/docs" class="nav-link">Docs</a>
    </div>
    <div class="nav-end">
      <a href="https://github.com/CodeSyncr/nimbus" target="_blank" rel="noopener" class="btn-gh">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/></svg>
        GitHub
      </a>
      <a href="/docs" rel="noopener" class="btn-start">Get started</a>
    </div>
  </nav>
</header>

{{ .embed }}

<!-- ── FOOTER ── -->
<footer>
  <div class="ft">
    <div class="fb">
      <a href="/" class="logo">
        <div class="logo-icon"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg></div>
        {{ .appName }}
      </a>
      <p class="ftag">The most productive way to build Go web applications.</p>
    </div>
