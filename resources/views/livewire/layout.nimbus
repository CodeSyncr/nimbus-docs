<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ .title }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cal+Sans:wght@400&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Geist:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #13161d;
    --surface2: #1a1e28;
    --border: #252a38;
    --border2: #2e3447;
    --text: #e8eaf0;
    --text2: #8892a4;
    --text3: #5a6478;
    --accent: #fb923c;
    --accent2: #f97316;
    --accent-dim: rgba(251,146,60,0.08);
    --green: #4ade80;
    --blue: #60a5fa;
    --purple: #a78bfa;
    --sidebar-w: 268px;
    --toc-w: 220px;
    --header-h: 56px;
    --radius: 8px;
    --mono: 'JetBrains Mono', monospace;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Geist', sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 14.5px;
    line-height: 1.7;
    min-height: 100vh;
  }

  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 99px; }

  .topnav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: var(--header-h);
    background: rgba(13,15,20,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 0;
  }

  .nav-logo-zone {
    width: var(--sidebar-w);
    display: flex; align-items: center;
    padding: 0 20px;
    gap: 10px;
    border-right: 1px solid var(--border);
    height: 100%;
    flex-shrink: 0;
  }

  .logo-mark {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, var(--accent), #ef4444);
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 700; color: #fff;
    letter-spacing: -0.5px;
    box-shadow: 0 0 20px rgba(251,146,60,0.35);
    flex-shrink: 0;
  }

  .logo-text {
    font-family: 'Geist', sans-serif;
    font-size: 15px; font-weight: 600;
    letter-spacing: -0.3px;
    color: var(--text);
  }

  .logo-text span { color: var(--accent); }

  .nav-version {
    font-size: 10.5px;
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid rgba(251,146,60,0.2);
    border-radius: 99px;
    padding: 1px 8px;
    font-family: var(--mono);
    font-weight: 500;
    margin-left: 2px;
  }

  .nav-center {
    flex: 1;
    display: flex; align-items: center;
    padding: 0 24px;
    gap: 4px;
  }

  .nav-links { display: flex; align-items: center; gap: 2px; margin-left: auto; }

  .nav-link {
    display: flex; align-items: center; gap: 5px;
    padding: 5px 10px; border-radius: 6px;
    color: var(--text2); font-size: 13px;
    text-decoration: none; transition: color 0.15s, background 0.15s;
    cursor: pointer;
  }
  .nav-link:hover { color: var(--text); background: var(--surface); }
  .nav-link.active { color: var(--text); }

  .nav-divider { width: 1px; height: 20px; background: var(--border); margin: 0 8px; }

  .nav-btn {
    display: flex; align-items: center; gap: 6px;
    padding: 5px 12px; border-radius: 6px;
    background: var(--accent); color: #1a0a00;
    font-size: 13px; font-weight: 600;
    border: none; cursor: pointer;
    transition: background 0.15s, transform 0.1s;
    text-decoration: none;
  }
  .nav-btn:hover { background: var(--accent2); transform: translateY(-1px); }

  .layout {
    display: flex;
    padding-top: var(--header-h);
    min-height: 100vh;
  }

  .sidebar {
    position: fixed;
    top: var(--header-h);
    left: 0;
    width: var(--sidebar-w);
    height: calc(100vh - var(--header-h));
    overflow-y: auto;
    border-right: 1px solid var(--border);
    background: var(--bg);
    padding: 20px 0 40px;
    display: flex; flex-direction: column;
  }

  .sidebar-section { margin-bottom: 6px; }

  .sidebar-label {
    font-size: 10.5px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--text3); padding: 10px 20px 4px;
  }

  .sidebar-item {
    display: flex; align-items: center; gap: 8px;
    padding: 5.5px 20px;
    color: var(--text2); font-size: 13.5px;
    text-decoration: none; cursor: pointer;
    transition: color 0.12s, background 0.12s;
    position: relative; border-radius: 0;
  }
  .sidebar-item:hover { color: var(--text); background: rgba(255,255,255,0.03); }
  .sidebar-item.active {
    color: var(--accent);
    background: var(--accent-dim);
  }
  .sidebar-item.active::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: var(--accent);
    border-radius: 0 2px 2px 0;
  }

  .sidebar-item .dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--text3); flex-shrink: 0;
    margin-left: 2px;
  }
  .sidebar-item.active .dot { background: var(--accent); }

  .sidebar-item.dir {
    font-size: 12.5px;
    padding-left: 26px;
    color: var(--text3);
  }
  .sidebar-item.dir:hover { color: var(--text2); }
  .sidebar-item.dir .dot { width: 4px; height: 4px; }

  .sidebar-divider { height: 1px; background: var(--border); margin: 12px 0; }

  .main {
    margin-left: var(--sidebar-w);
    margin-right: var(--toc-w);
    flex: 1;
    min-width: 0;
    padding: 48px 56px 80px;
    max-width: 860px;
  }

  .main.no-toc { margin-right: 0; max-width: none; }

  .breadcrumb {
    display: flex; align-items: center; gap: 6px;
    font-size: 12.5px; color: var(--text3); margin-bottom: 20px;
  }
  .breadcrumb a { color: var(--text3); text-decoration: none; }
  .breadcrumb a:hover { color: var(--text2); }
  .breadcrumb-sep { color: var(--text3); font-size: 11px; }
  .breadcrumb-current { color: var(--text2); }

  .page-hero { margin-bottom: 36px; animation: fadeUp 0.4s ease both; }

  .page-tag {
    display: inline-flex; align-items: center; gap: 5px;
    background: var(--accent-dim);
    border: 1px solid rgba(251,146,60,0.18);
    color: var(--accent); font-size: 11px; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 99px;
    margin-bottom: 14px;
  }

  .main h1 {
    font-family: 'Geist', sans-serif;
    font-size: 38px; font-weight: 700;
    letter-spacing: -1.5px; line-height: 1.1;
    color: var(--text); margin-bottom: 14px;
  }

  .page-lead {
    font-size: 16.5px; line-height: 1.65;
    color: var(--text2); max-width: 640px;
    font-weight: 300;
  }

  .main h2 {
    font-family: 'Geist', sans-serif;
    font-size: 22px; font-weight: 600;
    letter-spacing: -0.5px; color: var(--text);
    margin-top: 52px; margin-bottom: 14px;
    padding-top: 52px;
    border-top: 1px solid var(--border);
    scroll-margin-top: calc(var(--header-h) + 20px);
    animation: fadeUp 0.35s ease both;
  }
  .main h2:first-of-type { margin-top: 10px; padding-top: 0; border-top: none; }

  .main h3 {
    font-size: 16px; font-weight: 600;
    color: var(--text); margin-top: 32px; margin-bottom: 10px;
    scroll-margin-top: calc(var(--header-h) + 20px);
  }

  .main p { color: var(--text2); margin-bottom: 16px; line-height: 1.75; }

  .main a { color: var(--accent); text-decoration: none; }
  .main a:hover { text-decoration: underline; text-underline-offset: 3px; }

  .main code {
    font-family: var(--mono);
    font-size: 12.5px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 1.5px 6px;
    color: var(--accent);
  }

  .main ul { color: var(--text2); padding-left: 20px; margin-bottom: 16px; line-height: 1.85; }

  .main pre.code-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 20px;
    overflow-x: auto;
    margin: 20px 0;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--text2);
  }

  .main pre.code-block code {
    display: block;
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }

  .props-table {
    width: 100%; border-collapse: collapse;
    margin: 20px 0; font-size: 13.5px;
  }
  .props-table th {
    text-align: left; font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--text3); padding: 8px 14px;
    border-bottom: 1px solid var(--border);
  }
  .props-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    color: var(--text2); vertical-align: top;
  }
  .props-table tr:last-child td { border-bottom: none; }
  .props-table tr:hover td { background: rgba(255,255,255,0.02); }

  .toc {
    position: fixed;
    top: var(--header-h);
    right: 0;
    width: var(--toc-w);
    height: calc(100vh - var(--header-h));
    overflow-y: auto;
    border-left: 1px solid var(--border);
    padding: 28px 20px;
  }

  .toc-label {
    font-size: 10.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--text3); margin-bottom: 12px;
  }

  .toc-item {
    display: block;
    font-size: 12.5px; color: var(--text3);
    text-decoration: none; padding: 4px 0;
    transition: color 0.12s;
    line-height: 1.4;
  }
  .toc-item:hover { color: var(--text2); }
  .toc-item.active { color: var(--accent); }

  .toc-divider { height: 1px; background: var(--border); margin: 16px 0; }

  .toc-action {
    display: flex; align-items: center; gap: 7px;
    font-size: 12.5px; color: var(--text3);
    text-decoration: none; cursor: pointer;
    transition: color 0.12s;
  }
  .toc-action:hover { color: var(--text2); }

  .nav-footer {
    display: flex; gap: 16px;
    margin-top: 56px; padding-top: 28px;
    border-top: 1px solid var(--border);
  }
  .nav-card {
    flex: 1; padding: 16px 18px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .nav-card:hover { border-color: var(--border2); background: var(--surface2); }
  .nav-card-label {
    font-size: 11px; color: var(--text3);
    text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600;
    margin-bottom: 6px;
  }
  .nav-card-title { font-size: 14px; font-weight: 600; color: var(--text); }
  .nav-card.next { text-align: right; }
  .nav-card.next .nav-card-label::after { content: ' →'; }
  .nav-card.prev .nav-card-label::before { content: '← '; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1100px) {
    .toc { display: none; }
    .main { margin-right: 0; max-width: none; }
  }

  @media (max-width: 768px) {
    .sidebar { display: none; }
    .main { margin-left: 0; padding: 32px 20px 60px; }
    .nav-logo-zone { width: auto; border-right: none; }
  }
</style>
</head>
<body data-doc-page="{{ .docPage }}">

<nav class="topnav">
  <div class="nav-logo-zone">
    <div class="logo-mark">⚡</div>
    <span class="logo-text">Nimbus <span>Livewire</span></span>
    <span class="nav-version">plugin</span>
  </div>
  <div class="nav-center">
    <div class="nav-links">
      <a href="/livewire/docs/quickstart" class="nav-link active">Docs</a>
      <a href="/" class="nav-link">App</a>
      <div class="nav-divider"></div>
      <a href="https://github.com/CodeSyncr/nimbus/tree/main/plugins/livewire" class="nav-btn" target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </div>
</nav>

<div class="layout">

  <aside class="sidebar" id="lw-sidebar">
    <div class="sidebar-section">
      <div class="sidebar-label">Getting Started</div>
      <a class="sidebar-item" data-page="quickstart" href="/livewire/docs/quickstart"><span class="dot"></span> Quickstart</a>
      <a class="sidebar-item" data-page="installation" href="/livewire/docs/installation"><span class="dot"></span> Installation</a>
      <a class="sidebar-item" data-page="upgrade-guide" href="/livewire/docs/upgrade-guide"><span class="dot"></span> Upgrade Guide</a>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">
      <div class="sidebar-label">Essentials</div>
      <a class="sidebar-item" data-page="components" href="/livewire/docs/components"><span class="dot"></span> Components</a>
      <a class="sidebar-item" data-page="pages" href="/livewire/docs/pages"><span class="dot"></span> Pages</a>
      <a class="sidebar-item" data-page="properties" href="/livewire/docs/properties"><span class="dot"></span> Properties</a>
      <a class="sidebar-item" data-page="actions" href="/livewire/docs/actions"><span class="dot"></span> Actions</a>
      <a class="sidebar-item" data-page="forms" href="/livewire/docs/forms"><span class="dot"></span> Forms</a>
      <a class="sidebar-item" data-page="events" href="/livewire/docs/events"><span class="dot"></span> Events</a>
      <a class="sidebar-item" data-page="lifecycle-hooks" href="/livewire/docs/lifecycle-hooks"><span class="dot"></span> Lifecycle Hooks</a>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">
      <div class="sidebar-label">Features</div>
      <a class="sidebar-item" data-page="alpine" href="/livewire/docs/alpine"><span class="dot"></span> Alpine</a>
      <a class="sidebar-item" data-page="styles" href="/livewire/docs/styles"><span class="dot"></span> Styles</a>
      <a class="sidebar-item" data-page="navigate" href="/livewire/docs/navigate"><span class="dot"></span> Navigate</a>
      <a class="sidebar-item" data-page="islands" href="/livewire/docs/islands"><span class="dot"></span> Islands</a>
      <a class="sidebar-item" data-page="lazy-loading" href="/livewire/docs/lazy-loading"><span class="dot"></span> Lazy Loading</a>
      <a class="sidebar-item" data-page="loading-states" href="/livewire/docs/loading-states"><span class="dot"></span> Loading States</a>
      <a class="sidebar-item" data-page="validation" href="/livewire/docs/validation"><span class="dot"></span> Validation</a>
      <a class="sidebar-item" data-page="forms" href="/livewire/docs/forms"><span class="dot"></span> File Uploads</a>
      <a class="sidebar-item" data-page="pagination" href="/livewire/docs/pagination"><span class="dot"></span> Pagination</a>
      <a class="sidebar-item" data-page="url-query-parameters" href="/livewire/docs/url-query-parameters"><span class="dot"></span> URL Query Parameters</a>
      <a class="sidebar-item" data-page="computed-properties" href="/livewire/docs/computed-properties"><span class="dot"></span> Computed Properties</a>
      <a class="sidebar-item" data-page="redirecting" href="/livewire/docs/redirecting"><span class="dot"></span> Redirecting</a>
      <a class="sidebar-item" data-page="file-downloads" href="/livewire/docs/file-downloads"><span class="dot"></span> File Downloads</a>
      <a class="sidebar-item" data-page="teleport" href="/livewire/docs/teleport"><span class="dot"></span> Teleport</a>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">
      <div class="sidebar-label">HTML Directives</div>
      <a class="sidebar-item" data-page="directives" href="/livewire/docs/directives"><span class="dot"></span> Overview</a>
      <a class="sidebar-item dir" data-page="wire-bind" href="/livewire/docs/wire-bind"><span class="dot"></span> wire:bind</a>
      <a class="sidebar-item dir" data-page="wire-click" href="/livewire/docs/wire-click"><span class="dot"></span> wire:click</a>
      <a class="sidebar-item dir" data-page="wire-submit" href="/livewire/docs/wire-submit"><span class="dot"></span> wire:submit</a>
      <a class="sidebar-item dir" data-page="wire-model" href="/livewire/docs/wire-model"><span class="dot"></span> wire:model</a>
      <a class="sidebar-item dir" data-page="wire-navigate" href="/livewire/docs/wire-navigate"><span class="dot"></span> wire:navigate</a>
      <a class="sidebar-item dir" data-page="wire-current" href="/livewire/docs/wire-current"><span class="dot"></span> wire:current</a>
      <a class="sidebar-item dir" data-page="wire-cloak" href="/livewire/docs/wire-cloak"><span class="dot"></span> wire:cloak</a>
      <a class="sidebar-item dir" data-page="wire-dirty" href="/livewire/docs/wire-dirty"><span class="dot"></span> wire:dirty</a>
      <a class="sidebar-item dir" data-page="wire-confirm" href="/livewire/docs/wire-confirm"><span class="dot"></span> wire:confirm</a>
      <a class="sidebar-item dir" data-page="wire-loading" href="/livewire/docs/wire-loading"><span class="dot"></span> wire:loading</a>
      <a class="sidebar-item dir" data-page="wire-transition" href="/livewire/docs/wire-transition"><span class="dot"></span> wire:transition</a>
      <a class="sidebar-item dir" data-page="wire-init" href="/livewire/docs/wire-init"><span class="dot"></span> wire:init</a>
      <a class="sidebar-item dir" data-page="wire-intersect" href="/livewire/docs/wire-intersect"><span class="dot"></span> wire:intersect</a>
      <a class="sidebar-item dir" data-page="wire-poll" href="/livewire/docs/wire-poll"><span class="dot"></span> wire:poll</a>
      <a class="sidebar-item dir" data-page="wire-offline" href="/livewire/docs/wire-offline"><span class="dot"></span> wire:offline</a>
      <a class="sidebar-item dir" data-page="wire-ignore" href="/livewire/docs/wire-ignore"><span class="dot"></span> wire:ignore</a>
      <a class="sidebar-item dir" data-page="wire-ref" href="/livewire/docs/wire-ref"><span class="dot"></span> wire:ref</a>
      <a class="sidebar-item dir" data-page="wire-show" href="/livewire/docs/wire-show"><span class="dot"></span> wire:show</a>
      <a class="sidebar-item dir" data-page="wire-text" href="/livewire/docs/wire-text"><span class="dot"></span> wire:text</a>
      <a class="sidebar-item dir" data-page="wire-replace" href="/livewire/docs/wire-replace"><span class="dot"></span> wire:replace</a>
      <a class="sidebar-item dir" data-page="wire-sort" href="/livewire/docs/wire-sort"><span class="dot"></span> wire:sort</a>
      <a class="sidebar-item dir" data-page="wire-stream" href="/livewire/docs/wire-stream"><span class="dot"></span> wire:stream</a>
    </div>

    <div class="sidebar-divider"></div>

    <div class="sidebar-section">
      <div class="sidebar-label">Testing</div>
      <a class="sidebar-item" data-page="testing" href="/livewire/docs/testing"><span class="dot"></span> How to test</a>
    </div>
  </aside>

  <main class="main lw-doc-embed">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/livewire/docs/quickstart">Livewire docs</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current">{{ .docNavTitle }}</span>
    </div>
    {{ .embed }}
    @if(or .docPrev .docNext)
    <div class="nav-footer">
      @if(.docPrev)
      <a href="{{ .docPrev }}" class="nav-card prev">
        <div class="nav-card-label">Previous</div>
        <div class="nav-card-title">{{ .docPrevTitle }}</div>
      </a>
      @endif
      @if(.docNext)
      <a href="{{ .docNext }}" class="nav-card next">
        <div class="nav-card-label">Next</div>
        <div class="nav-card-title">{{ .docNextTitle }}</div>
      </a>
      @endif
    </div>
    @endif
  </main>

  @if(.toc)
  <aside class="toc" id="lw-toc">
    <div class="toc-label">On this page</div>
    @each(toc)
    <a class="toc-item" href="#{{ .id }}">{{ .label }}</a>
    @endeach

    <div class="toc-divider"></div>
    <a class="toc-action" href="https://github.com/CodeSyncr/nimbus/tree/main/plugins/livewire" target="_blank" rel="noopener">⎋ View source</a>
  </aside>
  @endif

</div>

<script>
(function(){
  var slug = document.body.getAttribute('data-doc-page') || '';
  document.querySelectorAll('.sidebar-item[data-page]').forEach(function(el){
    el.classList.toggle('active', el.getAttribute('data-page') === slug);
  });

  var headings = document.querySelectorAll('.main.lw-doc-embed h2[id]');
  var tocLinks = document.querySelectorAll('#lw-toc .toc-item');

  function syncTOC(){
    var current = '';
    headings.forEach(function(h){
      if (window.scrollY >= h.offsetTop - 120) current = h.id;
    });
    if (!current && headings.length) current = headings[0].id;
    tocLinks.forEach(function(link){
      link.classList.toggle('active', link.getAttribute('href') === '#' + current);
    });
  }

  if (tocLinks.length) {
    window.addEventListener('scroll', syncTOC, { passive: true });
    syncTOC();
  }
})();
</script>

</body>
</html>
