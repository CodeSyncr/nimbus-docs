<!DOCTYPE html>
<html lang="en" class="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Horizon · {{ if .title }}{{ .title }}{{ else }}Dashboard{{ end }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config = { darkMode: 'class' };</script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --t-bg: 249 250 251;
      --t-bg-sidebar: 255 255 255;
      --t-bg-card: 255 255 255;
      --t-border: 229 231 235;
      --t-text: 17 24 39;
      --t-text-muted: 75 85 99;
      --t-text-subtle: 107 114 128;
      --t-accent: 99 102 241;
      --t-accent-hover: 79 70 229;
      --t-accent-muted: 238 242 255;
      --t-hover: 243 244 246;
      --t-active: 233 213 255;
      --t-success: 34 197 94;
      --t-warning: 234 179 8;
      --t-error: 239 68 68;
      --t-shadow: 0 1px 2px rgb(0 0 0 / 0.05);
      --t-shadow-lg: 0 4px 6px -1px rgb(0 0 0 / 0.07), 0 2px 4px -2px rgb(0 0 0 / 0.05);
      --horizon-sidebar-w: 16rem;
    }
    .dark {
      --t-bg: 17 24 39;
      --t-bg-sidebar: 31 41 55;
      --t-bg-card: 31 41 55;
      --t-border: 55 65 81;
      --t-text: 249 250 251;
      --t-text-muted: 209 213 219;
      --t-text-subtle: 156 163 175;
      --t-accent: 129 140 248;
      --t-accent-hover: 165 180 252;
      --t-accent-muted: 55 48 163;
      --t-hover: 55 65 81;
      --t-active: 76 29 149;
      --t-success: 74 222 128;
      --t-warning: 250 204 21;
      --t-error: 248 113 113;
      --t-shadow: 0 1px 3px rgb(0 0 0 / 0.25);
      --t-shadow-lg: 0 4px 6px -1px rgb(0 0 0 / 0.3), 0 2px 4px -2px rgb(0 0 0 / 0.2);
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; }
    .font-mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }
    .t-bg { background-color: rgb(var(--t-bg)); }
    .t-bg-sidebar { background-color: rgb(var(--t-bg-sidebar)); }
    .t-bg-card { background-color: rgb(var(--t-bg-card)); }
    .t-border { border-color: rgb(var(--t-border)); }
    .t-text { color: rgb(var(--t-text)); }
    .t-text-muted { color: rgb(var(--t-text-muted)); }
    .t-text-subtle { color: rgb(var(--t-text-subtle)); }
    .t-accent { color: rgb(var(--t-accent)); }
    .t-accent-bg { background-color: rgb(var(--t-accent-muted)); }
    .dark .t-accent-bg { background-color: rgb(var(--t-accent) / 0.12); }
    .t-hover:hover { background-color: rgb(var(--t-hover)); }
    .t-active { background-color: rgb(var(--t-active)); }
    .t-nav-active { background: linear-gradient(90deg, rgb(var(--t-accent) / 0.12) 0%, transparent 100%); color: rgb(var(--t-accent)); border-left: 3px solid rgb(var(--t-accent)); }
    .t-nav-inactive { color: rgb(var(--t-text-muted)); }
    .t-nav-inactive:hover { color: rgb(var(--t-text)); background-color: rgb(var(--t-hover)); }
    .t-card { background-color: rgb(var(--t-bg-card)); border: 1px solid rgb(var(--t-border)); box-shadow: var(--t-shadow); border-radius: 0.75rem; }
    .t-divide > * + * { border-top: 1px solid rgb(var(--t-border)); }
    .horizon-logo { background: linear-gradient(135deg, rgb(var(--t-accent)) 0%, rgb(139 92 246) 100%); }
    .dark .horizon-logo { background: linear-gradient(135deg, rgb(var(--t-accent)) 0%, rgb(167 139 250) 100%); }
  </style>
</head>
<body class="min-h-screen t-bg t-text transition-colors duration-200">
  <script>
    (function() {
      const stored = localStorage.getItem('horizon-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const dark = stored === 'dark' || (stored === null && prefersDark);
      document.documentElement.classList.toggle('dark', dark);
    })();
    function toggleHorizonTheme() {
      const dark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('horizon-theme', dark ? 'dark' : 'light');
    }
  </script>
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-[var(--horizon-sidebar-w)] border-r t-border t-bg-sidebar flex flex-col shrink-0 sticky top-0 h-screen transition-colors duration-200">
      <!-- Horizon brand -->
      <div class="p-5 border-b t-border">
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}" class="flex items-center gap-3 group">
          <span class="flex items-center justify-center w-10 h-10 rounded-xl horizon-logo shadow-lg group-hover:shadow-xl transition-shadow">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
            </svg>
          </span>
          <span class="font-bold text-lg t-text tracking-tight">Horizon</span>
        </a>
      </div>
      <!-- Nav -->
      <nav class="flex-1 overflow-y-auto py-4 px-3 space-y-0.5">
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "dashboard" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
          Dashboard
        </a>
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}/monitoring" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "monitoring" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Monitoring
        </a>
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}/metrics" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "metrics" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Metrics
        </a>
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}/batches" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "batches" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012 2h6a2 2 0 012 2v2M7 7h10"/></svg>
          Batches
        </a>
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}/pending" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "pending" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Pending jobs
        </a>
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}/completed" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "completed" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Completed jobs
        </a>
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}/silenced" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "silenced" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/><path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/></svg>
          Silenced jobs
        </a>
        <a href="{{ if .horizonPath }}{{ .horizonPath }}{{ else }}/horizon{{ end }}/failed" class="flex items-center gap-3 px-3 py-2.5 text-sm rounded-lg transition border-l-3 border-transparent {{ if eq .page "failed" }}t-nav-active{{ else }}t-nav-inactive{{ end }}">
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Failed jobs
        </a>
      </nav>
      <div class="p-4 border-t t-border">
        <a href="/" class="text-sm t-text-muted hover:t-text transition flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          Back to app
        </a>
      </div>
    </aside>
    <!-- Main -->
    <main class="flex-1 overflow-auto flex flex-col min-w-0">
      <header class="border-b t-border t-bg-sidebar px-6 py-4 flex items-center justify-between sticky top-0 z-10 backdrop-blur-sm bg-opacity-95">
        <h1 class="text-lg font-semibold t-text">{{ if .title }}{{ .title }}{{ else }}Dashboard{{ end }}</h1>
        <div class="flex items-center gap-2">
          <button type="button" onclick="toggleHorizonTheme()" class="p-2.5 rounded-xl t-text-subtle hover:t-text hover:t-hover transition border border-transparent hover:border-t-border" title="Toggle theme">
            <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </button>
        </div>
      </header>
      <div class="flex-1 max-w-6xl w-full mx-auto px-6 py-8">
        {{ .embed }}
      </div>
    </main>
  </div>
</body>
</html>
