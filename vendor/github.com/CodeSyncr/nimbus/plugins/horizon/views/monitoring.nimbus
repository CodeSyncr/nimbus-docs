@layout('horizon/layout')
<div class="space-y-8">
  <p class="t-text-muted text-sm max-w-2xl">
    Real-time monitoring of queue workload and throughput. Stats are in-memory since last app boot.
  </p>

  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar flex items-center justify-between">
      <span class="font-medium t-text">Queue workload</span>
      <span class="t-text-subtle text-xs">Per-queue dispatched, processed, failed</span>
    </div>
    <div class="divide-y t-divide">
      @if(.hasQueues)
      <div class="px-5 py-3 text-xs font-semibold t-text-subtle grid grid-cols-5 gap-4">
        <div>Queue</div>
        <div class="text-right">Dispatched</div>
        <div class="text-right">Processed</div>
        <div class="text-right">Failed</div>
        <div class="text-right">Last activity</div>
      </div>
      @each(.queues)
      <div class="px-5 py-3 grid grid-cols-5 gap-4 items-center text-sm hover:t-hover transition">
        <div class="t-text font-mono font-medium">{{ index . "name" }}</div>
        <div class="text-right t-text">{{ index . "dispatched" }}</div>
        <div class="text-right t-text">{{ index . "processed" }}</div>
        <div class="text-right {{ if index . "failed" }}text-red-600 dark:text-red-400 font-medium{{ else }}t-text{{ end }}">{{ index . "failed" }}</div>
        <div class="text-right t-text-subtle text-xs">
          {{ if index . "last_processed" }}{{ index . "last_processed" }}{{ else if index . "last_dispatched" }}{{ index . "last_dispatched" }}{{ else }}—{{ end }}
        </div>
      </div>
      @endeach
      @else
      <div class="px-5 py-12 text-center t-text-subtle text-sm">No queue activity yet.</div>
      @endif
    </div>
  </div>
</div>
