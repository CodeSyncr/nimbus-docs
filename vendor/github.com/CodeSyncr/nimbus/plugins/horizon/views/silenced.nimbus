@layout('horizon/layout')
<div class="space-y-8">
  <p class="t-text-muted text-sm max-w-2xl">
    Silenced jobs are an operational policy layer. This page shows current queue activity so you can decide which job classes to silence in your Horizon config.
  </p>

  <div class="t-card rounded-xl p-6">
    <h3 class="font-medium t-text mb-2">How to silence jobs</h3>
    <p class="t-text-subtle text-sm">Add job class names under your Horizon configuration and keep high-volume low-signal jobs out of your primary completed stream.</p>
  </div>

  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar">
      <span class="font-medium t-text">Current queue candidates</span>
      <span class="text-xs t-text-subtle ml-2">Queues with high dispatch and low failure are common silencing candidates.</span>
    </div>
    <div class="divide-y t-divide">
      @if(.hasQueues)
      <div class="px-5 py-3 text-xs font-semibold t-text-subtle grid grid-cols-5 gap-4">
        <div>Queue</div>
        <div class="text-right">Dispatched</div>
        <div class="text-right">Processed</div>
        <div class="text-right">Failed</div>
        <div class="text-right">Retry + Reclaim</div>
      </div>
      @each(.queues)
      <div class="px-5 py-3 grid grid-cols-5 gap-4 items-center text-sm">
        <div class="font-mono t-text">{{ index . "name" }}</div>
        <div class="text-right t-text">{{ index . "dispatched" }}</div>
        <div class="text-right t-text">{{ index . "processed" }}</div>
        <div class="text-right {{ if index . "failed" }}text-red-600 dark:text-red-400{{ else }}t-text{{ end }}">{{ index . "failed" }}</div>
        <div class="text-right t-text-subtle">{{ index . "retried" }} / {{ index . "reclaimed" }}</div>
      </div>
      @endeach
      @else
      <div class="px-5 py-12 text-center t-text-subtle text-sm">No queue activity yet.</div>
      @endif
    </div>
  </div>
</div>
