@layout('telescope/layout')
<div>
  <h1 class="text-2xl font-bold t-text mb-2">Cache</h1>
  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar flex items-center justify-between">
      <h2 class="font-semibold t-text">Cache operations</h2>
      <div class="flex items-center gap-3">
        <form method="GET" class="flex items-center gap-2">
          <input name="q" value="{{ .q }}" placeholder="Search…" class="text-sm px-3 py-1.5 rounded-lg t-code-block t-text w-56 focus:outline-none" />
          <input name="tag" value="{{ .tag }}" placeholder="Tag" class="text-sm px-3 py-1.5 rounded-lg t-code-block t-text w-28 focus:outline-none font-mono" />
          <button type="submit" class="text-sm px-3 py-1.5 rounded-lg t-accent-bg t-accent hover:opacity-90 transition">Go</button>
        </form>
        <a href="{{ .basePath }}" class="text-sm t-accent hover:opacity-80 transition">← Dashboard</a>
      </div>
    </div>
    <div class="px-5 py-3 border-b t-border flex flex-wrap gap-2 text-xs">
      <a href="?q={{ .q }}&tag=hit" class="px-2.5 py-1 rounded-full t-accent-bg t-accent font-mono">hit ({{ index .tagCounts "hit" }})</a>
      <a href="?q={{ .q }}&tag=miss" class="px-2.5 py-1 rounded-full t-accent-bg t-accent font-mono">miss ({{ index .tagCounts "miss" }})</a>
      <a href="?q={{ .q }}&tag=error" class="px-2.5 py-1 rounded-full t-accent-bg t-accent font-mono">error ({{ index .tagCounts "error" }})</a>
      <a href="?q={{ .q }}&tag=set" class="px-2.5 py-1 rounded-full t-accent-bg t-accent font-mono">set ({{ index .tagCounts "set" }})</a>
      <a href="?q={{ .q }}&tag=get" class="px-2.5 py-1 rounded-full t-accent-bg t-accent font-mono">get ({{ index .tagCounts "get" }})</a>
      <a href="?q={{ .q }}&tag=delete" class="px-2.5 py-1 rounded-full t-accent-bg t-accent font-mono">delete ({{ index .tagCounts "delete" }})</a>
      <a href="?q={{ .q }}&tag=remember" class="px-2.5 py-1 rounded-full t-accent-bg t-accent font-mono">remember ({{ index .tagCounts "remember" }})</a>
      <a href="?q={{ .q }}&tag=" class="px-2.5 py-1 rounded-full t-code-block t-text-muted font-mono">clear</a>
    </div>
    <div class="t-divide">
      @if(.empty)
      <div class="px-5 py-12 text-center t-text-subtle">No cache activity recorded yet.</div>
      @else
      @each(.entries)
      <a href="{{ $.basePath }}/entry/{{ .ID }}" class="block px-5 py-4 t-hover transition">
        <div class="flex items-center justify-between gap-4">
          <div class="min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-medium px-2.5 py-1 rounded-full t-accent-bg t-accent shrink-0">{{ index .Content "operation" }}</span>
              @if(index .Content "hit")
              <span class="text-xs font-medium px-2.5 py-1 rounded-full t-status-2xx shrink-0">hit</span>
              @endif
              <span class="t-text-subtle text-xs font-mono shrink-0">{{ .CreatedAt.Format "Jan 02 15:04:05" }}</span>
            </div>
            <div class="t-text font-mono text-sm break-all">{{ index .Content "key" }}</div>
          </div>
          <div class="text-right shrink-0">
            <div class="t-text-subtle text-sm">{{ index .Content "duration_ms" }}ms</div>
            @if(index .Content "ttl_ms")
            <div class="t-text-subtle text-xs font-mono">ttl {{ index .Content "ttl_ms" }}ms</div>
            @endif
          </div>
        </div>
      </a>
      @endeach
      @endif
    </div>
  </div>
</div>

