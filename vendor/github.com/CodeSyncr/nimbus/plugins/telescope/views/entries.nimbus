@layout('telescope/layout')
<div>
  <h1 class="text-2xl font-bold t-text mb-2">{{ .title }}</h1>
  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar flex items-center justify-between">
      <h2 class="font-semibold t-text">{{ .title }}</h2>
      <a href="/telescope" class="text-sm t-accent hover:opacity-80 transition">← Dashboard</a>
    </div>
    <div class="t-divide">
      @if(.empty)
      <div class="px-5 py-12 text-center t-text-subtle">No {{ .title }} recorded yet.</div>
      @else
      @each(.entries)
      <div class="px-5 py-4 t-hover transition">
        <div class="flex items-center gap-3 mb-1">
          <span class="text-xs font-medium px-2.5 py-1 rounded-full t-accent-bg t-accent shrink-0">{{ .Type }}</span>
          <span class="t-text-subtle text-xs">{{ .CreatedAt.Format "Jan 02 15:04:05" }}</span>
        </div>
        <div class="mt-2 grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-1">
          @range $k, $v := .Content
          <div class="flex items-baseline gap-2 text-sm">
            <span class="t-text-muted font-mono text-xs">{{ $k }}:</span>
            <span class="t-text break-all">{{ $v }}</span>
          </div>
          @endrange
        </div>
      </div>
      @endeach
      @endif
    </div>
  </div>
</div>
