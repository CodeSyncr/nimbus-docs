@layout('telescope/layout')
<!-- LIST -->
<div class="list-panel">
    <div class="panel-header">
      <span class="panel-title">{{ .title }}</span>
      <span class="panel-count">{{ if .empty }}0{{ else }}{{ len .entries }}{{ end }} entries</span>
    </div>

    <div class="filter-row">
      <a class="filter-chip {{ if eq .tag "" }}active{{ end }}" href="?q={{ .q }}&tag=" style="text-decoration:none;">All</a>
      {{ if index .tagCounts "error" }}<a class="filter-chip {{ if eq .tag "error" }}active{{ end }}" href="?q={{ .q }}&tag=error" style="text-decoration:none;">error</a>{{ end }}
      {{ if index .tagCounts "slow" }}<a class="filter-chip yellow {{ if eq .tag "slow" }}active{{ end }}" href="?q={{ .q }}&tag=slow" style="text-decoration:none;">slow</a>{{ end }}
      {{ if index .tagCounts "failed" }}<a class="filter-chip red {{ if eq .tag "failed" }}active{{ end }}" href="?q={{ .q }}&tag=failed" style="text-decoration:none;">failed</a>{{ end }}
      {{ if index .tagCounts "5xx" }}<a class="filter-chip red {{ if eq .tag "5xx" }}active{{ end }}" href="?q={{ .q }}&tag=5xx" style="text-decoration:none;">5xx</a>{{ end }}
      {{ if index .tagCounts "4xx" }}<a class="filter-chip yellow {{ if eq .tag "4xx" }}active{{ end }}" href="?q={{ .q }}&tag=4xx" style="text-decoration:none;">4xx</a>{{ end }}
      {{ if index .tagCounts "pipeline" }}<a class="filter-chip {{ if eq .tag "pipeline" }}active{{ end }}" href="?q={{ .q }}&tag=pipeline" style="text-decoration:none;">pipeline</a>{{ end }}
    </div>

    <div class="entries-list">
      @if(.empty)
      <div class="empty-state" style="padding: 24px;">
        <div class="empty-title">No {{ .title }}</div>
        <div class="empty-sub">Generate activity to see entries here</div>
      </div>
      @else
      @each(.entries)
      <a class="entry-item {{ if eq $.selectedID .ID }}selected{{ end }}"
         href="?q={{ $.q }}&tag={{ $.tag }}&selected={{ .ID }}" data-entry-id="{{ .ID }}" style="text-decoration:none;">
        <div class="entry-row1">
          <span class="method-badge {{ if and (or (eq $.watcher "query") (eq $.watcher "queries")) (index .Content "operation") }}op-{{ index .Content "operation" }}{{ end }}">{{ if and (or (eq $.watcher "query") (eq $.watcher "queries")) (index .Content "operation") }}{{ index .Content "operation" }}{{ else }}{{ .Type }}{{ end }}</span>
          <span class="entry-path">{{ if and (or (eq $.watcher "query") (eq $.watcher "queries")) (index .Content "table") }}{{ index .Content "table" }}{{ else }}{{ if index .Content "path" }}{{ index .Content "path" }}{{ else }}{{ if index .Content "name" }}{{ index .Content "name" }}{{ else }}{{ if index .Content "command" }}{{ index .Content "command" }}{{ else }}{{ if index .Content "summary" }}{{ index .Content "summary" }}{{ else }}{{ if index .Content "sql" }}{{ index .Content "sql" }}{{ else }}{{ .ID }}{{ end }}{{ end }}{{ end }}{{ end }}{{ end }}{{ end }}</span>
          <span class="status-code">{{ .CreatedAt.Format "15:04:05" }}</span>
        </div>
        <div class="entry-row2">
          {{ if index .Content "duration_ms" }}<span class="entry-dur">{{ index .Content "duration_ms" }}ms</span>{{ else }}<span class="entry-dur">—</span>{{ end }}
        </div>
      </a>
      @endeach
      @endif
    </div>
  </div>

<!-- DETAIL -->
<div class="detail-panel">
  <div class="empty-state" id="detailEmpty">
    <div class="empty-title">Select an entry</div>
    <div class="empty-sub">Choose one from the list to inspect details</div>
  </div>

  <div id="detailContent" class="hidden" style="display:flex; flex-direction:column; height:100%; overflow:hidden;">
    <div class="detail-header">
      <div class="detail-title-row">
        <span class="method-badge" id="d-type" style="background: var(--accent-dim); color: var(--accent);"></span>
        <span class="detail-path" id="d-id"></span>
        <span class="status-code detail-status mono" id="d-time"></span>
      </div>
      <div class="detail-meta-row">
        <div class="detail-meta-item">
          <span class="detail-meta-label">Watcher</span>
          <span class="detail-meta-val" id="d-watcher"></span>
        </div>
        <div class="detail-meta-item">
          <span class="detail-meta-label">Duration</span>
          <span class="detail-meta-val accent" id="d-dur">—</span>
        </div>
      </div>
    </div>

    <div class="detail-tabs">
      <div class="detail-tab active" onclick="setTab(this,'overview')">Overview</div>
      <div class="detail-tab" onclick="setTab(this,'json')">JSON</div>
    </div>

    <div class="detail-body">
      <div class="tab-content active" id="tab-overview">
        <div class="detail-section">
          <div class="detail-section-title">Content</div>
          <div class="kv-row-wrap">
            <table class="kv-table" id="d-content-table"></table>
          </div>
        </div>
      </div>
      <div class="tab-content" id="tab-json">
        <div class="detail-section">
          <div class="detail-section-title">Entry JSON</div>
          <div class="code-block" id="d-json"></div>
          <div style="margin-top: 10px;">
            <a class="filter-chip" data-raw-entry-link id="d-raw" href="#" style="text-decoration:none;">Open raw entry</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
 

<script>
  // Persist list scroll + update detail without navigation
  let __TEL_ENTRIES = (function() {
    const b64 = "{{ .entriesB64 }}";
    if (!b64) return [];
    try { return JSON.parse(atob(b64)); } catch { return []; }
  })();

  function __fmtTime(s) {
    if (!s) return '';
    try {
      const d = new Date(s);
      // If browser can't parse it, don't show "Invalid Date"
      if (isNaN(d.getTime())) return '';
      return d.toLocaleString(undefined, { month: 'short', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' });
    } catch { return String(s); }
  }

  function __escapeHtml(v) {
    return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  function __opClass(op) {
    const o = String(op || '').toUpperCase();
    if (!o) return '';
    return 'op-' + o.replace(/[^A-Z0-9_-]/g, '');
  }

  function __fmtCell(v) {
    if (v === null || v === undefined) return '';
    if (typeof v === 'string') return v;
    if (typeof v === 'number' || typeof v === 'boolean' || typeof v === 'bigint') return String(v);
    try { return JSON.stringify(v, null, 2); } catch { return String(v); }
  }

  function __renderEntryDetail(entry) {
    const empty = document.getElementById('detailEmpty');
    const content = document.getElementById('detailContent');
    if (!entry) {
      if (empty) empty.style.display = 'flex';
      if (content) {
        content.classList.add('hidden');
        content.style.display = 'none';
      }
      return;
    }

    if (empty) empty.style.display = 'none';
    if (content) {
      content.classList.remove('hidden');
      content.style.display = 'flex';
    }

    let typ = entry.Type || entry.type || '';
    const id = entry.ID || entry.id || '';
    const created = entry.CreatedAt || entry.createdAt || '';
    const watcher = "{{ .watcher }}";
    const c = entry.Content || entry.content || {};
    const isQueryWatcher = (watcher === 'query' || watcher === 'queries');
    if (isQueryWatcher) typ = c.operation || c.op || typ;

    const dType = document.getElementById('d-type');
    if (dType) {
      dType.textContent = typ;
      dType.className = 'method-badge ' + __opClass(typ);
    }
    const dID = document.getElementById('d-id');
    if (dID) dID.textContent = id;
    const dTime = document.getElementById('d-time');
    if (dTime) dTime.textContent = __fmtTime(created);
    const dWatcher = document.getElementById('d-watcher');
    if (dWatcher) dWatcher.textContent = watcher;
    const dDur = document.getElementById('d-dur');
    if (dDur) dDur.textContent = (c && c.duration_ms != null) ? (String(c.duration_ms) + 'ms') : '—';

    const table = document.getElementById('d-content-table');
    if (table) {
      const keys = Object.keys(c || {});
      keys.sort();
      table.innerHTML = keys.map(k => `<tr><td>${__escapeHtml(k)}</td><td><pre style="margin:0; white-space:pre-wrap; word-break:break-word;">${__escapeHtml(__fmtCell(c[k]))}</pre></td></tr>`).join('') || '<tr><td>—</td><td>Empty</td></tr>';
    }

    const jsonEl = document.getElementById('d-json');
    if (jsonEl) jsonEl.textContent = JSON.stringify(entry, null, 2);

    const raw = document.getElementById('d-raw');
    if (raw) raw.setAttribute('href', "{{ .basePath }}/entry/" + id);
  }

  function __telSetSelected(id) {
    const list = document.querySelector('.entries-list');
    if (list) sessionStorage.setItem('telescope:listScroll', String(list.scrollTop || 0));

    document.querySelectorAll('[data-entry-id]').forEach(el => {
      el.classList.toggle('selected', el.getAttribute('data-entry-id') === id);
    });

    // Update URL without reload
    const u = new URL(window.location.href);
    u.searchParams.set('selected', id);
    history.pushState({ selected: id }, '', u.toString());

    const entry = __TEL_ENTRIES.find(e => (e.ID || e.id) === id);
    __renderEntryDetail(entry);
    return false;
  }

  // Intercept clicks
  document.addEventListener('click', function(e) {
    const a = e.target && e.target.closest ? e.target.closest('a[data-entry-id]') : null;
    if (!a) return;
    e.preventDefault();
    __telSetSelected(a.getAttribute('data-entry-id'));
  });

  // Restore list scroll after render
  (function() {
    const list = document.querySelector('.entries-list');
    if (!list) return;
    const v = sessionStorage.getItem('telescope:listScroll');
    if (v) list.scrollTop = parseInt(v, 10) || 0;
  })();

  // Initial detail render
  (function() {
    const u = new URL(window.location.href);
    const sel = u.searchParams.get('selected');
    const first = __TEL_ENTRIES[0];
    const initial = sel ? __TEL_ENTRIES.find(e => (e.ID || e.id) === sel) : first;
    if (initial) __renderEntryDetail(initial);
  })();

  // Live polling (no reload)
  let __pollTimer = null;
  let __lastTopID = ((__TEL_ENTRIES[0] && (__TEL_ENTRIES[0].ID || __TEL_ENTRIES[0].id)) || '');
  function __poll() {
    if (window.Pulse && !window.Pulse.isLive()) return;
    const type = "{{ .watcher }}";
    const api = new URL("{{ .basePath }}/api/entries", window.location.origin);
    api.searchParams.set('type', type);
    api.searchParams.set('limit', '50');
    const cur = new URL(window.location.href);
    const q = cur.searchParams.get('q') || '';
    const tag = cur.searchParams.get('tag') || '';
    api.searchParams.set('q', q);
    api.searchParams.set('tag', tag);

    fetch(api.toString(), { headers: { 'Accept': 'application/json' } })
      .then(r => r.ok ? r.json() : null)
      .then(data => {
        if (!data || !data.entries) return;
        const incoming = data.entries || [];
        const prevTop = (__TEL_ENTRIES[0] && (__TEL_ENTRIES[0].ID || __TEL_ENTRIES[0].id)) || '';
        const nextTop = (incoming[0] && (incoming[0].ID || incoming[0].id)) || '';
        if (prevTop === nextTop && incoming.length === __TEL_ENTRIES.length) return;
        __TEL_ENTRIES = incoming;
        if (nextTop && nextTop !== __lastTopID) {
          __lastTopID = nextTop;
          if (window.Pulse) window.Pulse.showToast("New {{ .title }} captured");
        }

        const list = document.querySelector('.entries-list');
        const st = list ? list.scrollTop : 0;
        const selId = cur.searchParams.get('selected') || nextTop;

        const html = __TEL_ENTRIES.map(e => {
          const id = e.ID || e.id;
          const typ = e.Type || e.type || '';
          const created = e.CreatedAt || e.createdAt || '';
          const c = e.Content || e.content || {};
          const isQueryType = (type === 'query' || type === 'queries');
          const title = (isQueryType ? (c.table || '') : '') || c.path || c.name || c.command || c.summary || c.sql || id;
          const dur = (c.duration_ms != null) ? (String(c.duration_ms) + 'ms') : '—';
          let badge = typ;
          if (isQueryType) badge = c.operation || badge;
          let t = '';
          try {
            const dt = new Date(created);
            if (!isNaN(dt.getTime())) {
              t = dt.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', second:'2-digit'});
            }
          } catch {}
          return `
            <a class="entry-item ${id === selId ? 'selected' : ''}"
               href="?q=${encodeURIComponent(q)}&tag=${encodeURIComponent(tag)}&selected=${encodeURIComponent(id)}"
               data-entry-id="${__escapeHtml(id)}" style="text-decoration:none;">
              <div class="entry-row1">
                <span class="method-badge ${__opClass(badge)}">${__escapeHtml(badge)}</span>
                <span class="entry-path">${__escapeHtml(title)}</span>
                <span class="status-code">${__escapeHtml(t)}</span>
              </div>
              <div class="entry-row2">
                <span class="entry-dur">${__escapeHtml(dur)}</span>
              </div>
            </a>`;
        }).join('');

        if (list && html) {
          list.innerHTML = html;
          list.scrollTop = st;
        }

        const selected = __TEL_ENTRIES.find(e => (e.ID || e.id) === selId) || __TEL_ENTRIES[0];
        if (selected) __renderEntryDetail(selected);
      })
      .catch(() => {});
  }

  function __startPolling() {
    if (__pollTimer) clearInterval(__pollTimer);
    __pollTimer = setInterval(__poll, 3000);
  }
  __startPolling();
  window.addEventListener('pulse-live-changed', function(e) {
    if (!e || !e.detail) return;
    if (e.detail.live) __poll();
  });

  function setTab(el, name) {
    document.querySelectorAll('.detail-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    var p = document.getElementById('tab-' + name);
    if (p) p.classList.add('active');
  }
</script>
