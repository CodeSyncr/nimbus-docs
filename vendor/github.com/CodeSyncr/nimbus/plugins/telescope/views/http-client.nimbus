@layout('telescope/layout')
<div>
  <h1 class="text-2xl font-bold t-text mb-2">HTTP Client</h1>
  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar flex items-center justify-between">
      <h2 class="font-semibold t-text">Outgoing requests</h2>
      <div class="flex items-center gap-3">
        <form method="GET" class="flex items-center gap-2">
          <input name="q" value="{{ .q }}" placeholder="Search…" class="text-sm px-3 py-1.5 rounded-lg t-code-block t-text w-56 focus:outline-none" />
          <button type="submit" class="text-sm px-3 py-1.5 rounded-lg t-accent-bg t-accent hover:opacity-90 transition">Go</button>
        </form>
        <a href="{{ .basePath }}" class="text-sm t-accent hover:opacity-80 transition">← Dashboard</a>
      </div>
    </div>
    <div class="t-divide">
      @if(.empty)
      <div class="px-5 py-12 text-center t-text-subtle">No HTTP client requests recorded yet.</div>
      @else
      @each(.entries)
      <a href="{{ $.basePath }}/entry/{{ .ID }}" class="block px-5 py-4 t-hover transition">
        <div class="flex items-center gap-4">
          <span class="text-xs font-medium px-2.5 py-1 rounded-full t-accent-bg t-accent shrink-0">{{ index .Content "status" }}</span>
          <span class="t-text-muted font-mono text-sm w-16 shrink-0">{{ index .Content "method" }}</span>
          <span class="t-text font-mono text-sm break-all flex-1 min-w-0">{{ index .Content "url" }}</span>
          <span class="t-text-subtle text-sm shrink-0">{{ index .Content "duration_ms" }}ms</span>
        </div>
      </a>
      @endeach
      @endif
    </div>
  </div>
</div>

