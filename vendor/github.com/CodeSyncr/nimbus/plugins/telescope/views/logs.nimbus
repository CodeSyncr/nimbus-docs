@layout('telescope/layout')
<div>
  <h1 class="text-2xl font-bold t-text mb-2">Logs</h1>
  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar flex items-center justify-between">
      <h2 class="font-semibold t-text">Application Logs</h2>
      <a href="/telescope" class="text-sm t-accent hover:opacity-80 transition">← Dashboard</a>
    </div>
    <div class="t-divide">
      @if(.empty)
      <div class="px-5 py-12 text-center t-text-subtle">No logs recorded. Use telescope.Log() to record log entries.</div>
      @else
      @each(.entries)
      <div class="px-5 py-4 t-hover transition flex items-center gap-3">
        <span class="text-xs font-medium px-2.5 py-1 rounded-full t-accent-bg t-accent shrink-0">{{ index .Content "level" }}</span>
        <span class="t-text-muted text-sm">{{ index .Content "message" }}</span>
      </div>
      @endeach
      @endif
    </div>
  </div>
</div>
