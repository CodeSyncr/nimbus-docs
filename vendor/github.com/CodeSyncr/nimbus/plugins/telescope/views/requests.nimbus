@layout('telescope/layout')
<div>
  <h1 class="text-2xl font-bold t-text mb-2">Requests</h1>
  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar flex items-center justify-between">
      <h2 class="font-semibold t-text">HTTP Requests</h2>
      <a href="/telescope" class="text-sm t-accent hover:opacity-80 transition">← Dashboard</a>
    </div>
    <div class="t-divide">
      @if(.empty)
      <div class="px-5 py-12 text-center t-text-subtle">No requests recorded yet.</div>
      @else
      @each(.entries)
      <a href="/telescope/requests/{{ .ID }}" class="block px-5 py-4 flex items-center gap-4 t-hover transition">
        <span class="text-xs font-medium px-2.5 py-1 rounded-full {{ $s := index .Content "response_status" }}{{ if and $s (ge $s 200) (lt $s 300) }}t-status-2xx{{ else }}{{ if and $s (ge $s 400) (lt $s 500) }}t-status-4xx{{ else }}{{ if and $s (ge $s 500) }}t-status-5xx{{ else }}t-accent-bg t-accent{{ end }}{{ end }}{{ end }}">{{ $s }}</span>
        <span class="t-text-muted font-mono text-sm w-16">{{ index .Content "method" }}</span>
        <span class="t-text font-mono text-sm break-all flex-1">{{ index .Content "path" }}</span>
        <span class="t-text-subtle text-sm">{{ index .Content "duration_ms" }}ms</span>
      </a>
      @endeach
      @endif
    </div>
  </div>
</div>
