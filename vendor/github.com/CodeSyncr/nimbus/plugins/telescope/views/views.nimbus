@layout('telescope/layout')
<div>
  <h1 class="text-2xl font-bold t-text mb-2">Views</h1>
  <div class="t-card rounded-xl overflow-hidden">
    <div class="px-5 py-4 border-b t-border t-bg-sidebar flex items-center justify-between">
      <h2 class="font-semibold t-text">Rendered Views</h2>
      <a href="/telescope" class="text-sm t-accent hover:opacity-80 transition">← Dashboard</a>
    </div>
    <div class="t-divide">
      @if(.empty)
      <div class="px-5 py-12 text-center t-text-subtle">No views recorded. View watcher coming soon.</div>
      @else
      @each(.entries)
      <div class="px-5 py-4 flex items-center gap-4 t-hover transition">
        <span class="t-text font-mono text-sm">{{ index .Content "name" }}</span>
      </div>
      @endeach
      @endif
    </div>
  </div>
</div>
